@using HRMS.Core.Application.Interfaces
@using MudBlazor
@inject IUserService UserService
@inject ISnackbar Snackbar
@inject IHttpContextAccessor HttpContextAccessor

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">Change Password</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">@UserName</MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="_form" @bind-IsValid="_isValid">
            <MudTextField @bind-Value="_newPassword"
                         Label="New Password *"
                         Variant="Variant.Outlined"
                         InputType="@(_showNew ? InputType.Text : InputType.Password)"
                         Required="true"
                         RequiredError="Password is required"
                         Validation="@(new Func<string, string?>(ValidatePassword))"
                         Adornment="Adornment.End"
                         AdornmentIcon="@(_showNew ? Icons.Material.Filled.Visibility : Icons.Material.Filled.VisibilityOff)"
                         OnAdornmentClick="@(() => _showNew = !_showNew)"
                         FullWidth="true"
                         Class="mb-3"
                         HelperText="Min 8 chars: uppercase, lowercase, number, special character" />

            <MudTextField @bind-Value="_confirmPassword"
                         Label="Confirm Password *"
                         Variant="Variant.Outlined"
                         InputType="@(_showConfirm ? InputType.Text : InputType.Password)"
                         Required="true"
                         RequiredError="Please confirm the password"
                         Validation="@(new Func<string, string?>(ValidateConfirm))"
                         Adornment="Adornment.End"
                         AdornmentIcon="@(_showConfirm ? Icons.Material.Filled.Visibility : Icons.Material.Filled.VisibilityOff)"
                         OnAdornmentClick="@(() => _showConfirm = !_showConfirm)"
                         FullWidth="true" />
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Disabled="@_isSaving">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Save" Disabled="@(!_isValid || _isSaving)">
            @if (_isSaving)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
            }
            Save Password
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance? MudDialog { get; set; }

    [Parameter] public int UserId { get; set; }
    [Parameter] public string UserName { get; set; } = string.Empty;
    [Parameter] public int TenantId { get; set; }
    [Parameter] public int AdminUserId { get; set; }

    private MudForm? _form;
    private bool _isValid;
    private bool _isSaving;
    private string _newPassword = string.Empty;
    private string _confirmPassword = string.Empty;
    private bool _showNew;
    private bool _showConfirm;

    private string? ValidatePassword(string value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return "Password is required.";
        if (value.Length < 8)
            return "Password must be at least 8 characters.";
        if (!System.Text.RegularExpressions.Regex.IsMatch(value,
            @"^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[@$!%*?&])[A-Za-z\d@$!%*?&]{8,}$"))
            return "Must contain uppercase, lowercase, number, and special character (@$!%*?&).";
        return null;
    }

    private string? ValidateConfirm(string value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return "Please confirm the password.";
        if (value != _newPassword)
            return "Passwords do not match.";
        return null;
    }

    private async Task Save()
    {
        await _form!.Validate();
        if (!_isValid) return;

        try
        {
            _isSaving = true;
            var ip = GetClientIpAddress();
            await UserService.ChangePasswordAsync(UserId, _newPassword, TenantId, AdminUserId, ip);
            Snackbar.Add("Password changed successfully.", Severity.Success);
            MudDialog?.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isSaving = false;
        }
    }

    private void Cancel() => MudDialog?.Cancel();

    private string? GetClientIpAddress()
    {
        try
        {
            var ctx = HttpContextAccessor.HttpContext;
            if (ctx == null) return null;
            var fwd = ctx.Request.Headers["X-Forwarded-For"].FirstOrDefault();
            if (!string.IsNullOrEmpty(fwd))
                return fwd.Split(',')[0].Trim();
            var real = ctx.Request.Headers["X-Real-IP"].FirstOrDefault();
            if (!string.IsNullOrEmpty(real))
                return real;
            return ctx.Connection.RemoteIpAddress?.ToString();
        }
        catch { return null; }
    }
}
