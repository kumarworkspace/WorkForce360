@using HRMS.Core.Application.DTOs
@using MudBlazor
@inject ILeaveTypeMasterService LeaveTypeMasterService
@inject ISnackbar Snackbar
@inject ILogger<LeaveTypeDialog> Logger

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">@(LeaveType == null ? "Add Leave Type" : "Edit Leave Type")</MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="form" @bind-IsValid="@isValid">
            <MudTextField @bind-Value="@_leaveTypeName" 
                         Label="Leave Type Name *" 
                         Variant="Variant.Outlined" 
                         Required="true"
                         RequiredError="Leave type name is required"
                         FullWidth="true" />
            <MudNumericField @bind-Value="@_maxDaysPerYear" 
                           Label="Max Days Per Year *" 
                           Variant="Variant.Outlined" 
                           Required="true"
                           Min="0"
                           Max="365"
                           FullWidth="true" />
            <MudCheckBox T="bool" @bind-Value="@_isPaid" Color="Color.Primary" Class="mt-3">
                <MudText Typo="Typo.body2">Is Paid Leave</MudText>
            </MudCheckBox>
            @if (LeaveType != null)
            {
                <MudCheckBox T="bool" @bind-Value="@_isActive" Color="Color.Primary" Class="mt-3">
                    <MudText Typo="Typo.body2">Is Active</MudText>
                </MudCheckBox>
            }
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Save" Disabled="@(!isValid)">Save</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance? MudDialog { get; set; }
    [Parameter] public LeaveTypeMasterDto? LeaveType { get; set; }
    [Parameter] public int TenantId { get; set; }
    [Parameter] public int UserId { get; set; }

    private MudForm? form;
    private bool isValid;
    private string _leaveTypeName = string.Empty;
    private decimal _maxDaysPerYear = 0;
    private bool _isPaid = true;
    private bool _isActive = true;

    protected override void OnInitialized()
    {
        if (LeaveType != null)
        {
            _leaveTypeName = LeaveType.LeaveTypeName;
            _maxDaysPerYear = LeaveType.MaxDaysPerYear;
            _isPaid = LeaveType.IsPaid;
            _isActive = LeaveType.IsActive;
        }
    }

    private void Cancel()
    {
        MudDialog?.Cancel();
    }

    private async Task Save()
    {
        if (!isValid) return;

        try
        {
            if (LeaveType == null)
            {
                var createRequest = new CreateLeaveTypeMasterDto
                {
                    LeaveTypeName = _leaveTypeName,
                    MaxDaysPerYear = _maxDaysPerYear,
                    IsPaid = _isPaid
                };
                var result = await LeaveTypeMasterService.CreateAsync(createRequest, TenantId, UserId);
                MudDialog?.Close(DialogResult.Ok(result));
            }
            else
            {
                var updateRequest = new UpdateLeaveTypeMasterDto
                {
                    LeaveTypeId = LeaveType.LeaveTypeId,
                    LeaveTypeName = _leaveTypeName,
                    MaxDaysPerYear = _maxDaysPerYear,
                    IsPaid = _isPaid,
                    IsActive = _isActive
                };
                var result = await LeaveTypeMasterService.UpdateAsync(updateRequest, TenantId, UserId);
                MudDialog?.Close(DialogResult.Ok(result));
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error saving leave type");
            Snackbar.Add($"Error saving leave type: {ex.Message}", Severity.Error);
        }
    }
}





