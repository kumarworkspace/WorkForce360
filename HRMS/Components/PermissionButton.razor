@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@using HRMS.Core.Application.Interfaces
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IAuthorizationHelper AuthorizationHelper

@if (_hasPermission)
{
    <MudButton @attributes="AdditionalAttributes"
               Variant="@Variant"
               Color="@Color"
               Size="@Size"
               StartIcon="@StartIcon"
               EndIcon="@EndIcon"
               Disabled="@Disabled"
               OnClick="@OnClick"
               Class="@Class"
               Style="@Style">
        @ChildContent
    </MudButton>
}
else
{
    <MudButton @attributes="AdditionalAttributes"
               Variant="@Variant"
               Color="@Color"
               Size="@Size"
               StartIcon="@StartIcon"
               EndIcon="@EndIcon"
               Disabled="true"
               Class="@Class"
               Style="@Style"
               Title="@Tooltip">
        @ChildContent
    </MudButton>
}

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public string ModuleName { get; set; } = string.Empty;
    [Parameter] public int RequiredAccessLevel { get; set; } = 1; // Default: View Access (1)
    [Parameter] public Variant Variant { get; set; } = Variant.Filled;
    [Parameter] public Color Color { get; set; } = Color.Primary;
    [Parameter] public Size Size { get; set; } = Size.Medium;
    [Parameter] public string? StartIcon { get; set; }
    [Parameter] public string? EndIcon { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public EventCallback<MouseEventArgs> OnClick { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter] public string? Style { get; set; }
    [Parameter] public string? Tooltip { get; set; } = "You do not have permission to perform this action";
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private bool _hasPermission = false;
    private int _userId = 0;
    private int _tenantId = 0;

    protected override async Task OnInitializedAsync()
    {
        if (string.IsNullOrEmpty(ModuleName))
        {
            _hasPermission = true; // If no module specified, allow (for backward compatibility)
            return;
        }

        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (!user.Identity?.IsAuthenticated ?? true)
        {
            _hasPermission = false;
            return;
        }

        var userIdClaim = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        var tenantIdClaim = user.FindFirst("TenantId")?.Value;

        if (string.IsNullOrEmpty(userIdClaim) || !int.TryParse(userIdClaim, out _userId))
        {
            _hasPermission = false;
            return;
        }

        if (string.IsNullOrEmpty(tenantIdClaim) || !int.TryParse(tenantIdClaim, out _tenantId))
        {
            _hasPermission = false;
            return;
        }

        // Check access level for the module
        var accessLevel = await AuthorizationHelper.GetModuleAccessLevelAsync(_userId, ModuleName, _tenantId);
        _hasPermission = accessLevel >= RequiredAccessLevel;
    }
}

