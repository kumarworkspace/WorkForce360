    private async Task SaveStaff()
    {
        // Basic validation
        if (string.IsNullOrWhiteSpace(_request.Name))
        {
            Snackbar.Add("Name is required", Severity.Warning);
            return;
        }
        
        if (string.IsNullOrWhiteSpace(_request.Email))
        {
            Snackbar.Add("Email is required", Severity.Warning);
            return;
        }
        
        if (string.IsNullOrWhiteSpace(_request.Division))
        {
            Snackbar.Add("Division is required", Severity.Warning);
            return;
        }
        
        if (string.IsNullOrWhiteSpace(_request.Department))
        {
            Snackbar.Add("Department is required", Severity.Warning);
            return;
        }
        
        if (string.IsNullOrWhiteSpace(_request.Position))
        {
            Snackbar.Add("Position is required", Severity.Warning);
            return;
        }

        try
        {
            _isSaving = true;
            
            if (IsEditMode && _updateRequest != null)
            {
                _updateRequest.Name = _request.Name;
                _updateRequest.Company = _request.Company;
                _updateRequest.DateOfBirth = _request.DateOfBirth;
                _updateRequest.Email = _request.Email;
                _updateRequest.PhoneNumber = _request.PhoneNumber;
                _updateRequest.Address = _request.Address;
                _updateRequest.IdentityCard = _request.IdentityCard;
                _updateRequest.Division = _request.Division;
                _updateRequest.Department = _request.Department;
                _updateRequest.Position = _request.Position;
                _updateRequest.DateJoined = _request.DateJoined;
                _updateRequest.RetirementDate = _request.RetirementDate;
                _updateRequest.ReportingManagerId = _request.ReportingManagerId;
                _updateRequest.EducationDetails = _request.EducationDetails;
                _updateRequest.ExperienceDetails = _request.ExperienceDetails;
                
                await StaffService.UpdateAsync(_updateRequest, _tenantId, _userId, null);
                Snackbar.Add("Employee updated successfully", Severity.Success);
                
                // Reload the staff data to refresh the form
                await LoadStaffAsync();
            }
            else
            {
                var createdStaff = await StaffService.CreateAsync(_request, _tenantId, _userId, null);
                Snackbar.Add("Employee created successfully", Severity.Success);
                
                // Upload pending documents after staff is created
                if (_pendingFiles.Any() && createdStaff != null)
                {
                    foreach (var pendingFile in _pendingFiles)
                    {
                        try
                        {
                            using var stream = pendingFile.File.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024);
                            await StaffService.UploadDocumentAsync(createdStaff.StaffId, _tenantId, pendingFile.DocumentType, stream, pendingFile.FileName, _userId);
                        }
                        catch (Exception ex)
                        {
                            Logger?.LogError(ex, "Error uploading pending document: {FileName}", pendingFile.FileName);
                            Snackbar.Add($"Error uploading {pendingFile.FileName}: {ex.Message}", Severity.Warning);
                        }
                    }
                }
                
                // Clear pending files after upload
                _pendingFiles.Clear();
                
                // Upload pending photo if exists
                if (_selectedPhoto != null && createdStaff != null)
                {
                    try
                    {
                        using var stream = _selectedPhoto.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024);
                        var filePath = await StaffService.UploadPhotoAsync(createdStaff.StaffId, _tenantId, stream, _selectedPhoto.Name, _userId);
                        _existingPhotoUrl = $"/{filePath.Replace('\\', '/')}";
                        _photoPreviewUrl = string.Empty;
                        _selectedPhoto = null;
                    }
                    catch (Exception ex)
                    {
                        Logger?.LogError(ex, "Error uploading pending photo: {FileName}", _selectedPhoto.Name);
                        Snackbar.Add($"Error uploading photo: {ex.Message}", Severity.Warning);
                    }
                }
                
                // Redirect to edit form with the new StaffId to stay on the form
                if (createdStaff != null)
                {
                    Navigation.NavigateTo($"/hrms/employees/form/{createdStaff.StaffId}");
                }
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error saving employee: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isSaving = false;
        }
    }

