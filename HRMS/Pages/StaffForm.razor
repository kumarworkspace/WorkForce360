    private async Task HandlePhotoSelected(InputFileChangeEventArgs e)
    {
        try
        {
            if (e.File == null)
            {
                return;
            }

            // Validate file type
            var extension = Path.GetExtension(e.File.Name).ToLowerInvariant();
            if (!new[] { ".jpg", ".jpeg", ".png", ".gif" }.Contains(extension))
            {
                Snackbar.Add("Invalid file type. Please select JPG, PNG, or GIF image.", Severity.Error);
                return;
            }

            // Validate file size (5MB max)
            const long maxFileSize = 5 * 1024 * 1024;
            if (e.File.Size > maxFileSize)
            {
                Snackbar.Add("File size exceeds 5MB limit", Severity.Error);
                return;
            }

            _selectedPhoto = e.File;
            _photoFileName = e.File.Name;

            // Create preview using base64
            using var stream = e.File.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024);
            using var memoryStream = new MemoryStream();
            await stream.CopyToAsync(memoryStream);
            var imageBytes = memoryStream.ToArray();
            var base64Image = Convert.ToBase64String(imageBytes);
            _photoPreviewUrl = $"data:image/{extension.TrimStart('.')};base64,{base64Image}";
            
            // Clear existing photo URL when new photo is selected
            _existingPhotoUrl = string.Empty;
            
            // If in edit mode, upload immediately
            if (IsEditMode && StaffId > 0)
            {
                await UploadPhotoAsync();
            }

            StateHasChanged();
        }
        catch (Exception ex)
        {
            Logger?.LogError(ex, "Error handling photo selection");
            Snackbar.Add($"Error selecting photo: {ex.Message}", Severity.Error);
        }
    }

    private async Task UploadPhotoAsync()
    {
        if (_selectedPhoto == null)
        {
            return;
        }

        try
        {
            _isUploadingPhoto = true;
            StateHasChanged();

            using var stream = _selectedPhoto.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024);
            var filePath = await StaffService.UploadPhotoAsync(StaffId, _tenantId, stream, _selectedPhoto.Name, _userId);
            
            // Update preview URL to use the uploaded file
            _existingPhotoUrl = $"/{filePath.Replace('\\', '/')}";
            _photoPreviewUrl = string.Empty;
            _photoFileName = string.Empty;
            _selectedPhoto = null;

            Snackbar.Add("Photo uploaded successfully", Severity.Success);
        }
        catch (Exception ex)
        {
            Logger?.LogError(ex, "Error uploading photo");
            Snackbar.Add($"Error uploading photo: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isUploadingPhoto = false;
            StateHasChanged();
        }
    }

    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        try
        {
            if (string.IsNullOrEmpty(_selectedDocumentType))
            {
                Snackbar.Add("Please select a document type first", Severity.Warning);
                return;
            }

            if (e.File == null)
            {
                return;
            }

            // Validate file size (5MB max)
            const long maxFileSize = 5 * 1024 * 1024;
            if (e.File.Size > maxFileSize)
            {
                Snackbar.Add("File size exceeds 5MB limit", Severity.Error);
                return;
            }

            _selectedFile = e.File;
            _selectedFileName = e.File.Name;

            // If in edit mode, upload immediately
            if (IsEditMode && StaffId > 0)
            {
                await UploadDocumentAsync();
            }
            else
            {
                // For create mode, add to pending list
                _uploadedDocuments.Add(new LegalDocumentDto
                {
                    Id = 0,
                    DocumentType = _selectedDocumentType,
                    FileName = _selectedFileName
                });
                _pendingFiles.Add(new PendingFile
                {
                    File = _selectedFile!,
                    DocumentType = _selectedDocumentType,
                    FileName = _selectedFileName
                });
                StateHasChanged();
            }

            // Reset selection
            _selectedDocumentType = string.Empty;
            _selectedFileName = string.Empty;
            _selectedFile = null;
        }
        catch (Exception ex)
        {
            Logger?.LogError(ex, "Error handling file selection");
            Snackbar.Add($"Error selecting file: {ex.Message}", Severity.Error);
        }
    }

    private async Task UploadDocumentAsync()
    {
        if (_selectedFile == null || string.IsNullOrEmpty(_selectedDocumentType))
        {
            return;
        }

        try
        {
            _isUploadingDocument = true;
            StateHasChanged();

            using var stream = _selectedFile.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024);
            await StaffService.UploadDocumentAsync(StaffId, _tenantId, _selectedDocumentType, stream, _selectedFile.Name, _userId);
            
            // Reload documents
            var staff = await StaffService.GetByIdAsync(StaffId, _tenantId);
            if (staff != null && staff.LegalDocuments != null)
            {
                _uploadedDocuments = staff.LegalDocuments.ToList();
            }

            Snackbar.Add("Document uploaded successfully", Severity.Success);
        }
        catch (Exception ex)
        {
            Logger?.LogError(ex, "Error uploading document");
            Snackbar.Add($"Error uploading document: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isUploadingDocument = false;
            StateHasChanged();
        }
    }

    private async Task DeleteDocument(LegalDocumentDto document)
    {
        if (document.Id <= 0)
        {
            return;
        }

        try
        {
            var result = await StaffService.DeleteDocumentAsync(document.Id, _tenantId, _userId);
            if (result)
            {
                _uploadedDocuments.Remove(document);
                Snackbar.Add("Document deleted successfully", Severity.Success);
                StateHasChanged();
            }
            else
            {
                Snackbar.Add("Error deleting document", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Logger?.LogError(ex, "Error deleting document");
            Snackbar.Add($"Error deleting document: {ex.Message}", Severity.Error);
        }
    }

    private void RemovePendingDocument(LegalDocumentDto document)
    {
        if (document.Id > 0)
        {
            return; // Only remove pending documents
        }

        _uploadedDocuments.Remove(document);
        
        // Also remove from pending files
        var pendingFile = _pendingFiles.FirstOrDefault(p => p.FileName == document.FileName && p.DocumentType == document.DocumentType);
        if (pendingFile != null)
        {
            _pendingFiles.Remove(pendingFile);
        }
        
        StateHasChanged();
    }

    private class PendingFile
    {
        public IBrowserFile File { get; set; } = null!;
        public string DocumentType { get; set; } = string.Empty;
        public string FileName { get; set; } = string.Empty;
    }

    private List<PendingFile> _pendingFiles = new();

    private void CalculateTotalExperience(ExperienceDetailDto experience)
    {
        if (experience.StartDate.HasValue && experience.EndDate.HasValue)
        {
            var startDate = experience.StartDate.Value;
            var endDate = experience.EndDate.Value;
            
            if (endDate >= startDate)
            {
                var years = endDate.Year - startDate.Year;
                var months = endDate.Month - startDate.Month;
                
                if (months < 0)
                {
                    years--;
                    months += 12;
                }
                
                if (years > 0 && months > 0)
                {
                    experience.TotalExperience = $"{years} year(s) {months} month(s)";
                }
                else if (years > 0)
                {
                    experience.TotalExperience = $"{years} year(s)";
                }
                else if (months > 0)
                {
                    experience.TotalExperience = $"{months} month(s)";
                }
                else
                {
                    experience.TotalExperience = "Less than 1 month";
                }
            }
            else
            {
                experience.TotalExperience = string.Empty;
            }
        }
        else
        {
            experience.TotalExperience = string.Empty;
        }
        
        StateHasChanged();
    }
