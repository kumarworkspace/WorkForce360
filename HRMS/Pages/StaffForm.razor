    private async Task LoadReportingManagersAsync()
    {
        try
        {
            // Get all staff for the tenant using StaffService
            var allStaff = await StaffService.GetPagedAsync(_tenantId, 1, 1000, null, null, null);
            _reportingManagers = allStaff.Items
                .Where(s => s.IsActive)
                .Select(s => new StaffDto
                {
                    StaffId = s.StaffId,
                    Name = s.Name ?? string.Empty,
