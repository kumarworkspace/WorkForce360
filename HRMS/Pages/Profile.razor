    private async Task SaveEducationAsync(EducationDetailDto education, bool isNew)
    {
        if (!_staffId.HasValue || _staff == null)
        {
            Snackbar.Add("Profile not found", Severity.Error);
            return;
        }

        try
        {
            var updateRequest = new UpdateStaffRequest
            {
                StaffId = _staff.StaffId,
                EmployeeCode = _staff.EmployeeCode,
                Name = _staff.Name,
                Company = _staff.Company,
                DateOfBirth = _staff.DateOfBirth,
                GenderId = _staff.GenderId,
                Email = _staff.Email,
                PhoneNumber = _staff.PhoneNumber,
                Address = _staff.Address,
                IdentityCard = _staff.IdentityCard,
                Division = _staff.Division,
                Department = _staff.Department,
                Position = _staff.Position,
                EmploymentStatusId = _staff.EmploymentStatusId,
                DateJoined = _staff.DateJoined,
                RetirementDate = _staff.RetirementDate,
                EducationDetails = _staff.EducationDetails.ToList(),
                ExperienceDetails = _staff.ExperienceDetails.ToList()
            };

            if (isNew)
            {
                updateRequest.EducationDetails.Add(education);
            }
            else
            {
                var index = updateRequest.EducationDetails.FindIndex(e => e.Id == education.Id);
                if (index >= 0)
                {
                    updateRequest.EducationDetails[index] = education;
                }
            }

            var ipAddress = GetClientIpAddress();
            await StaffService.UpdateAsync(updateRequest, _tenantId, _userId, ipAddress);
            
            // Log audit
            await LogAuditAsync(ActionType.Update, 
                isNew ? $"Added education: {education.Qualification} from {education.Institution}" 
                      : $"Updated education: {education.Qualification} from {education.Institution}");

            Snackbar.Add(isNew ? "Education added successfully" : "Education updated successfully", Severity.Success);
            await LoadProfileAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error saving education");
            Snackbar.Add($"Error saving education: {ex.Message}", Severity.Error);
        }
    }

