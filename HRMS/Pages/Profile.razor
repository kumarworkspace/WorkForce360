    private string GetClientIpAddress()
    {
        try
        {
            return HttpContextAccessor.HttpContext?.Connection.RemoteIpAddress?.ToString() ?? "Unknown";
        }
        catch
        {
            return "Unknown";
        }
    }

    private async Task LogAuditAsync(ActionType actionType, string description)
    {
        try
        {
            var ipAddress = GetClientIpAddress();
            var auditLog = new AuditLog
            {
                TenantId = _tenantId,
                UserId = _userId,
                ActionType = actionType,
                Description = $"Profile: {description}",
                IPAddress = ipAddress,
                IsActive = true,
                CreatedBy = _userId,
                CreatedDate = DateTime.UtcNow
            };

            await UnitOfWork.AuditLogs.AddAsync(auditLog);
            await UnitOfWork.SaveChangesAsync();
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to log audit entry");
            // Don't throw - audit logging failure shouldn't break the operation
        }
    }
