@page "/admin/audit-logs"
@layout MainLayout
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using HRMS.Core.Application.Interfaces
@using HRMS.Core.Application.DTOs
@using ClosedXML.Excel
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IAuditLogService AuditLogService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject IJSRuntime JSRuntime

<PageTitle>Audit Logs</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="pa-4">
    <div class="d-flex align-center justify-space-between mb-4">
        <div>
            <MudText Typo="Typo.h4" Style="font-weight: 600; color: #1a237e; margin-bottom: 4px;">Audit Logs</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">Track all system activity — who did what, when, and from where</MudText>
        </div>
        <div class="d-flex align-center" style="gap: 8px;">
            <MudChip T="string" Color="Color.Primary" Icon="@Icons.Material.Filled.Shield" Size="Size.Medium">
                @(_pagedResult?.TotalCount ?? 0) Total Events
            </MudChip>
            <MudButton Variant="Variant.Outlined"
                      Color="Color.Success"
                      StartIcon="@Icons.Material.Filled.TableChart"
                      Size="Size.Medium"
                      Disabled="@_isExporting"
                      OnClick="ExportToExcelAsync">
                Export Excel
            </MudButton>
            <MudButton Variant="Variant.Outlined"
                      Color="Color.Error"
                      StartIcon="@Icons.Material.Filled.PictureAsPdf"
                      Size="Size.Medium"
                      Disabled="@_isExporting"
                      OnClick="ExportToPdfAsync">
                Export PDF
            </MudButton>
        </div>
    </div>

    <!-- Stats Cards -->
    @if (_pagedResult != null)
    {
        <MudGrid Class="mb-4" Spacing="3">
            @foreach (var stat in _actionStats)
            {
                <MudItem xs="6" sm="4" md="2">
                    <MudPaper Elevation="2" Class="pa-3" Style="border-radius: 8px; text-align: center;">
                        <MudIcon Icon="@GetActionIcon(stat.Key)" Color="@GetActionTypeColor(stat.Key)" Size="Size.Medium" />
                        <MudText Typo="Typo.h6" Style="font-weight: 700; margin-top: 4px;">@stat.Value</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">@stat.Key</MudText>
                    </MudPaper>
                </MudItem>
            }
        </MudGrid>
    }

    <!-- Search and Filters -->
    <MudPaper Class="pa-4 mb-4" Elevation="2" Style="background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%); border-radius: 8px;">
        <MudGrid Spacing="3">
            <MudItem xs="12" md="3">
                <MudTextField Value="@_searchTerm"
                             ValueChanged="@OnSearchChangedCallback"
                             Label="Search by Description, Module, IP"
                             Variant="Variant.Outlined"
                             Adornment="Adornment.Start"
                             AdornmentIcon="@Icons.Material.Filled.Search"
                             Immediate="true" />
            </MudItem>
            <MudItem xs="12" md="2">
                <MudSelect Value="@_selectedActionType"
                          ValueChanged="@OnActionTypeChangedCallback"
                          Label="Action Type"
                          Variant="Variant.Outlined"
                          Clearable="true"
                          T="string">
                    <MudSelectItem Value="@("Create")">Create</MudSelectItem>
                    <MudSelectItem Value="@("Update")">Update</MudSelectItem>
                    <MudSelectItem Value="@("Delete")">Delete</MudSelectItem>
                    <MudSelectItem Value="@("View")">View</MudSelectItem>
                    <MudSelectItem Value="@("Approve")">Approve</MudSelectItem>
                    <MudSelectItem Value="@("Reject")">Reject</MudSelectItem>
                    <MudSelectItem Value="@("Login")">Login</MudSelectItem>
                    <MudSelectItem Value="@("Logout")">Logout</MudSelectItem>
                    <MudSelectItem Value="@("AccessDenied")">Access Denied</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="2">
                <MudSelect Value="@_selectedModule"
                          ValueChanged="@OnModuleChangedCallback"
                          Label="Module"
                          Variant="Variant.Outlined"
                          Clearable="true"
                          T="string">
                    <MudSelectItem Value="@("Authentication")">Authentication</MudSelectItem>
                    <MudSelectItem Value="@("User Management")">User Management</MudSelectItem>
                    <MudSelectItem Value="@("Role Management")">Role Management</MudSelectItem>
                    <MudSelectItem Value="@("Access Control")">Access Control</MudSelectItem>
                    <MudSelectItem Value="@("Staff")">Staff</MudSelectItem>
                    <MudSelectItem Value="@("Leave")">Leave</MudSelectItem>
                    <MudSelectItem Value="@("Training")">Training</MudSelectItem>
                    <MudSelectItem Value="@("Attendance")">Attendance</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="2">
                <MudDatePicker Label="Start Date"
                              Date="@_startDate"
                              DateChanged="@OnStartDateChanged"
                              Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="12" md="2">
                <MudDatePicker Label="End Date"
                              Date="@_endDate"
                              DateChanged="@OnEndDateChanged"
                              Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="12" md="1">
                <MudButton Variant="Variant.Outlined"
                          Color="Color.Error"
                          OnClick="ClearFilters"
                          FullWidth="true"
                          Style="margin-top: 4px;">
                    Clear
                </MudButton>
            </MudItem>
        </MudGrid>
    </MudPaper>

    @if (_isLoading)
    {
        <MudProgressLinear Indeterminate="true" />
    }
    else if (_pagedResult == null || !_pagedResult.Items.Any())
    {
        <MudPaper Class="pa-4" Elevation="2" Style="border-radius: 8px;">
            <MudText Typo="Typo.body1">No audit logs found.</MudText>
        </MudPaper>
    }
    else
    {
        <MudPaper Elevation="2" Style="border-radius: 8px; overflow: hidden;">
            <MudTable Items="_pagedResult.Items" Hover="true" Dense="true" Striped="true" Style="background-color: white;">
                <HeaderContent>
                    <MudTh>Date & Time</MudTh>
                    <MudTh>User</MudTh>
                    <MudTh>Role</MudTh>
                    <MudTh>Action Type</MudTh>
                    <MudTh>Module</MudTh>
                    <MudTh>Description</MudTh>
                    <MudTh>IP Address</MudTh>
                    <MudTh>Created By</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Date & Time">
                        <MudText Typo="Typo.body2" Style="font-weight: 500;">@context.CreatedDate.ToString("MMM dd, yyyy")</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">@context.CreatedDate.ToString("HH:mm:ss")</MudText>
                    </MudTd>
                    <MudTd DataLabel="User">
                        @if (!string.IsNullOrEmpty(context.UserName))
                        {
                            <MudText Typo="Typo.body2" Style="font-weight: 500;">@context.UserName</MudText>
                            @if (!string.IsNullOrEmpty(context.UserEmail))
                            {
                                <MudText Typo="Typo.caption" Color="Color.Secondary">@context.UserEmail</MudText>
                            }
                        }
                        else
                        {
                            <MudText Typo="Typo.body2" Color="Color.Secondary">-</MudText>
                        }
                    </MudTd>
                    <MudTd DataLabel="Role">
                        @if (!string.IsNullOrEmpty(context.UserRole))
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Primary">@context.UserRole</MudChip>
                        }
                        else
                        {
                            <MudText Typo="Typo.body2" Color="Color.Secondary">-</MudText>
                        }
                    </MudTd>
                    <MudTd DataLabel="Action Type">
                        <MudChip T="string"
                                Size="Size.Small"
                                Color="@GetActionTypeColor(context.ActionType)">
                            <MudIcon Icon="@GetActionIcon(context.ActionType)" Size="Size.Small" Class="mr-1" />
                            @context.ActionType
                        </MudChip>
                    </MudTd>
                    <MudTd DataLabel="Module">
                        @if (!string.IsNullOrEmpty(context.Module))
                        {
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Primary">@context.Module</MudChip>
                        }
                        else
                        {
                            <MudText Typo="Typo.body2" Color="Color.Secondary">-</MudText>
                        }
                    </MudTd>
                    <MudTd DataLabel="Description">
                        <MudText Typo="Typo.body2" Style="max-width: 300px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;" 
                                Title="@context.Description">
                            @context.Description
                        </MudText>
                    </MudTd>
                    <MudTd DataLabel="IP Address">
                        <MudText Typo="Typo.body2">@(context.IPAddress ?? "-")</MudText>
                    </MudTd>
                    <MudTd DataLabel="Created By">
                        @if (!string.IsNullOrEmpty(context.CreatedByName))
                        {
                            <MudText Typo="Typo.body2">@context.CreatedByName</MudText>
                        }
                        else
                        {
                            <MudText Typo="Typo.body2" Color="Color.Secondary">-</MudText>
                        }
                    </MudTd>
                </RowTemplate>
            </MudTable>

            <!-- Pagination -->
            <div class="d-flex align-center justify-space-between pa-3" style="background-color: #f5f5f5; border-top: 1px solid #e0e0e0;">
                <div class="d-flex align-center" style="gap: 8px;">
                    <MudText Typo="Typo.body2">Rows per page:</MudText>
                    <MudSelect T="int" Value="@_pageSize" ValueChanged="OnPageSizeChanged" Dense="true" Style="width:80px;" Variant="Variant.Outlined">
                        <MudSelectItem T="int" Value="10">10</MudSelectItem>
                        <MudSelectItem T="int" Value="25">25</MudSelectItem>
                        <MudSelectItem T="int" Value="50">50</MudSelectItem>
                        <MudSelectItem T="int" Value="100">100</MudSelectItem>
                    </MudSelect>
                </div>
                <MudText Typo="Typo.body2" Color="Color.Default">
                    Showing <strong>@((_pageNumber - 1) * _pageSize + 1)</strong> - <strong>@(Math.Min(_pageNumber * _pageSize, _pagedResult.TotalCount))</strong> of <strong>@_pagedResult.TotalCount</strong> audit logs
                </MudText>
                <MudPagination Count="@((int)Math.Ceiling((double)_pagedResult.TotalCount / _pageSize))"
                               Selected="@_pageNumber"
                               SelectedChanged="OnPageChanged"
                               ShowFirstButton="true"
                               ShowLastButton="true" />
            </div>
        </MudPaper>
    }
</MudContainer>

@code {
    private PagedResult<AuditLogDto>? _pagedResult;
    private Dictionary<string, int> _actionStats = new();
    private bool _isLoading = true;
    private int _tenantId;
    private int _userId;
    
    // Pagination
    private int _pageNumber = 1;
    private int _pageSize = 25;
    
    // Filters
    private string? _searchTerm;
    private string? _selectedActionType;
    private string? _selectedModule;
    private DateTime? _startDate;
    private DateTime? _endDate;
    
    // Debounce timer for search
    private System.Threading.Timer? _searchDebounceTimer;

    // Export
    private bool _isExporting = false;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        
        if (user.Identity?.IsAuthenticated != true)
        {
            Navigation.NavigateTo("/signin");
            return;
        }

        var tenantIdClaim = user.FindFirst("TenantId")?.Value;
        var userIdClaim = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;

        if (string.IsNullOrEmpty(tenantIdClaim) || string.IsNullOrEmpty(userIdClaim))
        {
            Snackbar.Add("Authentication error: Missing tenant or user information", Severity.Error);
            return;
        }

        _tenantId = int.Parse(tenantIdClaim);
        _userId = int.Parse(userIdClaim);

        await LoadAuditLogsAsync();
    }

    private async Task LoadAuditLogsAsync()
    {
        try
        {
            _isLoading = true;
            _pagedResult = await AuditLogService.GetPagedAsync(_tenantId, _pageNumber, _pageSize, _searchTerm, _selectedActionType, _startDate, _endDate, _selectedModule);

            // Build action stats from current page (load full stats separately)
            if (_pagedResult != null && string.IsNullOrEmpty(_searchTerm) && string.IsNullOrEmpty(_selectedActionType) && !_startDate.HasValue && !_endDate.HasValue && string.IsNullOrEmpty(_selectedModule))
            {
                var allLogs = await AuditLogService.GetPagedAsync(_tenantId, 1, 1000, null, null, null, null);
                _actionStats = allLogs.Items
                    .GroupBy(l => l.ActionType)
                    .ToDictionary(g => g.Key, g => g.Count());
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading audit logs: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private async Task OnPageChanged(int page)
    {
        _pageNumber = page;
        await LoadAuditLogsAsync();
    }

    private async Task OnPageSizeChanged(int pageSize)
    {
        _pageSize = pageSize;
        _pageNumber = 1;
        await LoadAuditLogsAsync();
    }

    private async Task OnSearchChanged(string? value)
    {
        _searchTerm = value;
        _pageNumber = 1;
        
        // Debounce search - wait 500ms after user stops typing
        _searchDebounceTimer?.Dispose();
        _searchDebounceTimer = new System.Threading.Timer(async _ =>
        {
            await InvokeAsync(async () =>
            {
                await LoadAuditLogsAsync();
                StateHasChanged();
            });
        }, null, 500, Timeout.Infinite);
    }

    private EventCallback<string?> OnSearchChangedCallback => EventCallback.Factory.Create<string?>(this, OnSearchChanged);

    private async Task OnActionTypeChanged(string? value)
    {
        _selectedActionType = value;
        _pageNumber = 1;
        await LoadAuditLogsAsync();
    }

    private EventCallback<string?> OnActionTypeChangedCallback => EventCallback.Factory.Create<string?>(this, OnActionTypeChanged);

    private async Task OnModuleChanged(string? value)
    {
        _selectedModule = value;
        _pageNumber = 1;
        await LoadAuditLogsAsync();
    }

    private EventCallback<string?> OnModuleChangedCallback => EventCallback.Factory.Create<string?>(this, OnModuleChanged);

    private async Task OnStartDateChanged(DateTime? date)
    {
        _startDate = date;
        _pageNumber = 1;
        await LoadAuditLogsAsync();
    }

    private async Task OnEndDateChanged(DateTime? date)
    {
        _endDate = date;
        _pageNumber = 1;
        await LoadAuditLogsAsync();
    }

    private async Task ClearFilters()
    {
        _searchTerm = null;
        _selectedActionType = null;
        _selectedModule = null;
        _startDate = null;
        _endDate = null;
        _pageNumber = 1;
        await LoadAuditLogsAsync();
    }

    private Color GetActionTypeColor(string actionType)
    {
        return actionType switch
        {
            "Create" => Color.Success,
            "Update" => Color.Info,
            "Delete" => Color.Error,
            "View" => Color.Default,
            "Approve" => Color.Success,
            "Reject" => Color.Warning,
            "Login" => Color.Tertiary,
            "Logout" => Color.Secondary,
            "AccessDenied" => Color.Error,
            _ => Color.Default
        };
    }

    private string GetActionIcon(string actionType)
    {
        return actionType switch
        {
            "Create" => Icons.Material.Filled.AddCircle,
            "Update" => Icons.Material.Filled.Edit,
            "Delete" => Icons.Material.Filled.DeleteForever,
            "View" => Icons.Material.Filled.Visibility,
            "Approve" => Icons.Material.Filled.CheckCircle,
            "Reject" => Icons.Material.Filled.Cancel,
            "Login" => Icons.Material.Filled.Login,
            "Logout" => Icons.Material.Filled.Logout,
            "AccessDenied" => Icons.Material.Filled.Block,
            _ => Icons.Material.Filled.Info
        };
    }

    private async Task<List<AuditLogDto>> GetAllFilteredLogsAsync()
    {
        var all = await AuditLogService.GetPagedAsync(_tenantId, 1, 10000, _searchTerm, _selectedActionType, _startDate, _endDate, _selectedModule);
        return all.Items.ToList();
    }

    private async Task ExportToExcelAsync()
    {
        try
        {
            _isExporting = true;
            StateHasChanged();

            var logs = await GetAllFilteredLogsAsync();

            using var workbook = new XLWorkbook();
            var sheet = workbook.Worksheets.Add("Audit Logs");

            // Header row
            sheet.Cell(1, 1).Value = "Date & Time";
            sheet.Cell(1, 2).Value = "User";
            sheet.Cell(1, 3).Value = "Email";
            sheet.Cell(1, 4).Value = "Role";
            sheet.Cell(1, 5).Value = "Action Type";
            sheet.Cell(1, 6).Value = "Module";
            sheet.Cell(1, 7).Value = "Description";
            sheet.Cell(1, 8).Value = "IP Address";
            sheet.Cell(1, 9).Value = "Created By";

            var headerRow = sheet.Row(1);
            headerRow.Style.Font.Bold = true;
            headerRow.Style.Fill.BackgroundColor = XLColor.FromHtml("#1a237e");
            headerRow.Style.Font.FontColor = XLColor.White;

            // Data rows
            for (int i = 0; i < logs.Count; i++)
            {
                var log = logs[i];
                var row = i + 2;
                sheet.Cell(row, 1).Value = log.CreatedDate.ToString("dd MMM yyyy HH:mm:ss");
                sheet.Cell(row, 2).Value = log.UserName ?? "-";
                sheet.Cell(row, 3).Value = log.UserEmail ?? "-";
                sheet.Cell(row, 4).Value = log.UserRole ?? "-";
                sheet.Cell(row, 5).Value = log.ActionType;
                sheet.Cell(row, 6).Value = log.Module ?? "-";
                sheet.Cell(row, 7).Value = log.Description;
                sheet.Cell(row, 8).Value = log.IPAddress ?? "-";
                sheet.Cell(row, 9).Value = log.CreatedByName ?? "-";
            }

            sheet.Columns().AdjustToContents();

            using var ms = new MemoryStream();
            workbook.SaveAs(ms);
            var bytes = ms.ToArray();
            var base64 = Convert.ToBase64String(bytes);
            var fileName = $"AuditLogs_{DateTime.Now:yyyyMMdd_HHmmss}.xlsx";

            await JSRuntime.InvokeVoidAsync("downloadFileFromBase64", base64,
                "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet", fileName);

            Snackbar.Add($"Exported {logs.Count} records to Excel.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Export failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isExporting = false;
            StateHasChanged();
        }
    }

    private async Task ExportToPdfAsync()
    {
        try
        {
            _isExporting = true;
            StateHasChanged();

            var logs = await GetAllFilteredLogsAsync();

            var sb = new System.Text.StringBuilder();
            sb.AppendLine("<!DOCTYPE html><html><head><meta charset='utf-8'>");
            sb.AppendLine("<title>Audit Logs</title>");
            sb.AppendLine("<style>");
            sb.AppendLine("body{font-family:Arial,sans-serif;font-size:11px;margin:20px;}");
            sb.AppendLine("h2{color:#1a237e;margin-bottom:4px;}");
            sb.AppendLine("p.subtitle{color:#666;margin-top:0;margin-bottom:12px;}");
            sb.AppendLine("table{width:100%;border-collapse:collapse;}");
            sb.AppendLine("th{background:#1a237e;color:white;padding:6px 8px;text-align:left;font-size:10px;}");
            sb.AppendLine("td{padding:5px 8px;border-bottom:1px solid #e0e0e0;font-size:10px;}");
            sb.AppendLine("tr:nth-child(even){background:#f5f5f5;}");
            sb.AppendLine("@media print{body{margin:10px;}}");
            sb.AppendLine("</style></head><body>");
            sb.AppendLine("<h2>Audit Logs</h2>");
            sb.AppendLine($"<p class='subtitle'>Exported on {DateTime.Now:dd MMM yyyy HH:mm} &mdash; {logs.Count} records");
            if (!string.IsNullOrEmpty(_searchTerm)) sb.Append($" | Search: {System.Net.WebUtility.HtmlEncode(_searchTerm)}");
            if (!string.IsNullOrEmpty(_selectedActionType)) sb.Append($" | Action: {_selectedActionType}");
            if (_startDate.HasValue) sb.Append($" | From: {_startDate.Value:dd MMM yyyy}");
            if (_endDate.HasValue) sb.Append($" | To: {_endDate.Value:dd MMM yyyy}");
            sb.AppendLine("</p>");
            sb.AppendLine("<table><thead><tr>");
            sb.AppendLine("<th>Date &amp; Time</th><th>User</th><th>Role</th><th>Action</th><th>Description</th><th>IP Address</th></tr></thead><tbody>");

            foreach (var log in logs)
            {
                sb.AppendLine("<tr>");
                sb.AppendLine($"<td>{log.CreatedDate:dd MMM yyyy HH:mm:ss}</td>");
                sb.AppendLine($"<td>{System.Net.WebUtility.HtmlEncode(log.UserName ?? "-")}<br/><small style='color:#666'>{System.Net.WebUtility.HtmlEncode(log.UserEmail ?? "")}</small></td>");
                sb.AppendLine($"<td>{System.Net.WebUtility.HtmlEncode(log.UserRole ?? "-")}</td>");
                sb.AppendLine($"<td>{System.Net.WebUtility.HtmlEncode(log.ActionType)}</td>");
                sb.AppendLine($"<td>{System.Net.WebUtility.HtmlEncode(log.Description)}</td>");
                sb.AppendLine($"<td>{System.Net.WebUtility.HtmlEncode(log.IPAddress ?? "-")}</td>");
                sb.AppendLine("</tr>");
            }

            sb.AppendLine("</tbody></table></body></html>");

            await JSRuntime.InvokeVoidAsync("openPrintWindow", sb.ToString());

            Snackbar.Add($"PDF preview opened with {logs.Count} records. Use browser Print → Save as PDF.", Severity.Info);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Export failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isExporting = false;
            StateHasChanged();
        }
    }
}

