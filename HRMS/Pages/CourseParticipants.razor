    private async Task LoadAvailableStaff()
    {
        try
        {
            var pagedResult = await StaffService.GetPagedAsync(_tenantId, 1, 1000, null, null, null);

            // Filter out staff that are already participants
            var existingParticipantIds = _courseDetail?.Participants?.Select(p => p.StaffId).ToHashSet() ?? new HashSet<int>();
            _availableStaff = pagedResult.Items
                .Where(s => !existingParticipantIds.Contains(s.StaffId))
                .ToList();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading available staff");
            Snackbar.Add("Error loading staff list", Severity.Error);
        }
    }

