@page "/tms/planning/{CoursePlanId:int}/participants"
@layout MainLayout
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using HRMS.Core.Application.Interfaces
@using HRMS.Core.Application.DTOs
@implements IDisposable
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject ICourseParticipantService ParticipantService
@inject IStaffService StaffService
@inject IAuthorizationHelper AuthorizationHelper
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject ILogger<CourseParticipants> Logger
@inject IJSRuntime JS

<PageTitle>Course Participants & Attendance</PageTitle>

@if (_isLoading)
{
    <MudContainer MaxWidth="MaxWidth.False" Class="pa-4">
        <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="200px" />
        <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="400px" Class="mt-4" />
    </MudContainer>
}
else if (_courseDetail == null)
{
    <MudContainer MaxWidth="MaxWidth.False" Class="pa-4">
        <MudAlert Severity="Severity.Error">Course plan not found</MudAlert>
        <MudButton OnClick="NavigateBack" Variant="Variant.Filled" Color="Color.Primary" Class="mt-4">
            Back to List
        </MudButton>
    </MudContainer>
}
else
{
    <MudContainer MaxWidth="MaxWidth.False" Class="pa-4">
        <!-- Header Section -->
        <div class="d-flex align-center justify-space-between mb-4">
            <div>
                <MudText Typo="Typo.h4" Style="font-weight: 600; color: #1a237e; margin-bottom: 4px;">
                    Course Participants & Attendance
                </MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">@_courseDetail.CourseTitle</MudText>
            </div>
            <MudButton Variant="Variant.Outlined"
                      Color="Color.Primary"
                      StartIcon="@Icons.Material.Filled.ArrowBack"
                      OnClick="NavigateBack">
                Back to List
            </MudButton>
        </div>

        <!-- Tabs -->
        <MudPaper Elevation="2" Style="border-radius: 8px;">
            <MudTabs Elevation="0" Rounded="true" Color="Color.Primary" ActivePanelIndex="@_activeTab" ActivePanelIndexChanged="OnTabChanged">
                <!-- Tab 1: Course Details & Add Participants -->
                <MudTabPanel Text="Participants" Icon="@Icons.Material.Filled.Group">
                    <MudGrid Class="pa-4">
                        <!-- Course Information Card -->
                        <MudItem xs="12">
                            <MudPaper Elevation="1" Class="pa-4" Style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; border-radius: 8px;">
                                <MudGrid Spacing="2">
                                    <MudItem xs="12" md="2">
                                        <MudText Typo="Typo.caption" Style="opacity: 0.9;">Course Code</MudText>
                                        <MudText Typo="Typo.body1" Style="font-weight: 600;">@_courseDetail.CourseCode</MudText>
                                    </MudItem>
                                    <MudItem xs="12" md="2">
                                        <MudText Typo="Typo.caption" Style="opacity: 0.9;">Date Range</MudText>
                                        <MudText Typo="Typo.body1" Style="font-weight: 600;">
                                            @_courseDetail.StartDate.ToString("dd MMM") - @_courseDetail.EndDate.ToString("dd MMM yyyy")
                                        </MudText>
                                    </MudItem>
                                    <MudItem xs="12" md="2">
                                        <MudText Typo="Typo.caption" Style="opacity: 0.9;">Timing</MudText>
                                        <MudText Typo="Typo.body1" Style="font-weight: 600;">
                                            @_courseDetail.StartTime.ToString(@"hh\:mm") - @_courseDetail.EndTime.ToString(@"hh\:mm")
                                        </MudText>
                                    </MudItem>
                                    <MudItem xs="12" md="2">
                                        <MudText Typo="Typo.caption" Style="opacity: 0.9;">Duration</MudText>
                                        <MudText Typo="Typo.body1" Style="font-weight: 600;">@_courseDetail.CourseDuration hours</MudText>
                                    </MudItem>
                                    <MudItem xs="12" md="2">
                                        <MudText Typo="Typo.caption" Style="opacity: 0.9;">Trainer</MudText>
                                        <MudText Typo="Typo.body1" Style="font-weight: 600;">@_courseDetail.TrainerName</MudText>
                                    </MudItem>
                                    <MudItem xs="12" md="2">
                                        <MudText Typo="Typo.caption" Style="opacity: 0.9;">Venue</MudText>
                                        <MudText Typo="Typo.body1" Style="font-weight: 600;">@_courseDetail.Venue</MudText>
                                    </MudItem>
                                </MudGrid>
                            </MudPaper>
                        </MudItem>

                        <!-- Add Participants Section -->
                        @if (_accessLevel >= 2)
                        {
                        <MudItem xs="12">
                            <MudPaper Elevation="1" Class="pa-4">
                                <MudText Typo="Typo.h6" Class="mb-3" Style="color: #1a237e; font-weight: 600;">
                                    Add Participants
                                </MudText>
                                <MudGrid Spacing="2">
                                    <MudItem xs="12" md="10">
                                        <MudSelect T="int"
                                                  Label="Select Staff Members"
                                                  MultiSelection="true"
                                                  @bind-SelectedValues="_selectedStaffIds"
                                                  Variant="Variant.Outlined"
                                                  AnchorOrigin="Origin.BottomCenter"
                                                  ToStringFunc="@(id => GetStaffDisplayName(id))">
                                            @foreach (var staff in _availableStaff)
                                            {
                                                <MudSelectItem Value="@staff.StaffId">@staff.Name (@staff.EmployeeCode)</MudSelectItem>
                                            }
                                        </MudSelect>
                                    </MudItem>
                                    <MudItem xs="12" md="2">
                                        <MudButton Variant="Variant.Filled"
                                                  Color="Color.Primary"
                                                  FullWidth="true"
                                                  Style="height: 56px;"
                                                  OnClick="AddParticipants"
                                                  Disabled="@(!_selectedStaffIds.Any() || _adding)">
                                            @if (_adding)
                                            {
                                                <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                                            }
                                            else
                                            {
                                                <span>Add</span>
                                            }
                                        </MudButton>
                                    </MudItem>
                                </MudGrid>
                            </MudPaper>
                        </MudItem>
                        }

                        <!-- Participants List -->
                        <MudItem xs="12">
                            <MudPaper Elevation="1" Class="pa-4">
                                <div class="d-flex align-center justify-space-between mb-3">
                                    <MudText Typo="Typo.h6" Style="color: #1a237e; font-weight: 600;">
                                        Current Participants (@_courseDetail.Participants.Count)
                                    </MudText>
                                    <MudButton Variant="Variant.Outlined"
                                              Color="Color.Primary"
                                              Size="Size.Small"
                                              StartIcon="@Icons.Material.Filled.Refresh"
                                              OnClick="LoadCourseData">
                                        Refresh
                                    </MudButton>
                                </div>

                                @if (!_courseDetail.Participants.Any())
                                {
                                    <div class="pa-4 text-center">
                                        <MudIcon Icon="@Icons.Material.Filled.GroupOff" Size="Size.Large" Color="Color.Secondary" />
                                        <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mt-2">
                                            No participants added yet
                                        </MudText>
                                    </div>
                                }
                                else
                                {
                                    <MudTable Items="@_courseDetail.Participants" Hover="true" Dense="true" Striped="true">
                                        <HeaderContent>
                                            <MudTh Style="background-color: #1a237e; color: white;">Employee Code</MudTh>
                                            <MudTh Style="background-color: #1a237e; color: white;">Name</MudTh>
                                            <MudTh Style="background-color: #1a237e; color: white;">Department</MudTh>
                                            <MudTh Style="background-color: #1a237e; color: white;">Position</MudTh>
                                            <MudTh Style="background-color: #1a237e; color: white;">Email</MudTh>
                                            <MudTh Style="background-color: #1a237e; color: white; text-align: center;">Enrolled On</MudTh>
                                            <MudTh Style="background-color: #1a237e; color: white; text-align: center;">Action</MudTh>
                                        </HeaderContent>
                                        <RowTemplate>
                                            <MudTd DataLabel="Employee Code">@context.EmployeeCode</MudTd>
                                            <MudTd DataLabel="Name">@context.StaffName</MudTd>
                                            <MudTd DataLabel="Department">@context.Department</MudTd>
                                            <MudTd DataLabel="Position">@context.Position</MudTd>
                                            <MudTd DataLabel="Email">@context.Email</MudTd>
                                            <MudTd DataLabel="Enrolled On" Style="text-align: center;">@context.CreatedDate.ToString("dd MMM yyyy")</MudTd>
                                            <MudTd DataLabel="Action" Style="text-align: center;">
                                                @if (_accessLevel >= 2)
                                                {
                                                    <MudTooltip Text="Remove Participant">
                                                        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                                      Size="Size.Small"
                                                                      Color="Color.Error"
                                                                      OnClick="@(() => RemoveParticipant(context.StaffId))" />
                                                    </MudTooltip>
                                                }
                                                else
                                                {
                                                    <MudText Typo="Typo.caption" Color="Color.Secondary">-</MudText>
                                                }
                                            </MudTd>
                                        </RowTemplate>
                                    </MudTable>
                                }
                            </MudPaper>
                        </MudItem>
                    </MudGrid>
                </MudTabPanel>

                <!-- Tab 2: Attendance Update -->
                <MudTabPanel Text="Attendance" Icon="@Icons.Material.Filled.CalendarMonth">
                    <div class="pa-4">
                        <div class="d-flex align-center justify-space-between mb-3">
                            <MudText Typo="Typo.h6" Style="color: #1a237e; font-weight: 600;">
                                Date-wise Attendance
                            </MudText>
                            <div class="d-flex gap-2 align-center">
                                @if (_hasUnsavedChanges)
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Warning">@_pendingChanges.Count Unsaved</MudChip>
                                }
                                <MudButton Variant="Variant.Outlined"
                                          Color="Color.Secondary"
                                          Size="Size.Small"
                                          StartIcon="@Icons.Material.Filled.QrCodeScanner"
                                          OnClick="@(() => Navigation.NavigateTo($"/tms/attendance/mark/{CoursePlanId}"))">
                                    Scan QR
                                </MudButton>
                                @if (_canMarkAttendance)
                                {
                                    <MudButton Variant="Variant.Filled"
                                              Color="Color.Success"
                                              Size="Size.Small"
                                              StartIcon="@Icons.Material.Filled.Save"
                                              OnClick="SaveCurrentAttendance"
                                              Disabled="@(_savingAttendance || !_attendanceGrid.Any())">
                                        @if (_savingAttendance)
                                        {
                                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                                        }
                                        Save Attendance
                                    </MudButton>
                                }
                                <MudButton Variant="Variant.Outlined"
                                          Color="Color.Primary"
                                          Size="Size.Small"
                                          StartIcon="@Icons.Material.Filled.Refresh"
                                          OnClick="LoadAttendanceGrid">
                                    Refresh
                                </MudButton>
                            </div>
                        </div>

                        @if (_loadingAttendance)
                        {
                            <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
                        }
                        else if (!_attendanceGrid.Any())
                        {
                            <div class="pa-4 text-center">
                                <MudIcon Icon="@Icons.Material.Filled.EventBusy" Size="Size.Large" Color="Color.Secondary" />
                                <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mt-2">
                                    No participants added. Please add participants first.
                                </MudText>
                            </div>
                        }
                        else
                        {
                            <div style="overflow-x: auto;">
                                <table class="mud-table mud-xs-table mud-table-dense mud-table-hover mud-table-striped" style="min-width: 800px;">
                                    <thead>
                                        <tr>
                                            <th style="background-color: #1a237e; color: white; position: sticky; left: 0; z-index: 10; min-width: 180px;">
                                                Participant
                                            </th>
                                            @foreach (var date in _dateRange)
                                            {
                                                <th style="background-color: #1a237e; color: white; text-align: center; min-width: 80px;">
                                                    <div>@date.ToString("dd MMM")</div>
                                                    <div style="font-size: 0.75rem; opacity: 0.8;">@date.ToString("ddd")</div>
                                                    @if (_canMarkAttendance && _attendanceGrid.Any())
                                                    {
                                                        <MudTooltip Text="Select All">
                                                            <MudCheckBox T="bool?"
                                                                        Value="@GetSelectAllState(date)"
                                                                        ValueChanged="@((bool? val) => ToggleSelectAll(date, val == true))"
                                                                        Color="Color.Warning"
                                                                        Dense="true"
                                                                        Style="margin-top: 2px;" />
                                                        </MudTooltip>
                                                    }
                                                </th>
                                            }
                                            <th style="background-color: #1a237e; color: white; text-align: center; min-width: 60px;">Total</th>
                                            <th style="background-color: #1a237e; color: white; text-align: center; min-width: 60px;">Present</th>
                                            <th style="background-color: #1a237e; color: white; text-align: center; min-width: 70px;">Att. %</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var participant in _attendanceGrid)
                                        {
                                            var enrolledOn = _courseDetail?.Participants
                                                .FirstOrDefault(p => p.StaffId == participant.StaffId)?.CreatedDate;
                                            <tr>
                                                <td style="position: sticky; left: 0; background-color: white; z-index: 5; font-weight: 500;">
                                                    <div>@participant.StaffName</div>
                                                    <div style="font-size: 0.75rem; color: #666;">@participant.EmployeeCode</div>
                                                    @if (enrolledOn.HasValue)
                                                    {
                                                        <div style="font-size: 0.7rem; color: #999;">Enrolled: @enrolledOn.Value.ToString("dd MMM yyyy")</div>
                                                    }
                                                </td>
                                                @foreach (var date in _dateRange)
                                                {
                                                    <td style="text-align: center;">
                                                        <MudCheckBox T="bool"
                                                                    Value="@participant.AttendanceByDate.GetValueOrDefault(date.ToString("yyyy-MM-dd"), false)"
                                                                    ValueChanged="@((bool val) => UpdateAttendance(participant.StaffId, date, val))"
                                                                    Color="Color.Success"
                                                                    Dense="true"
                                                                    Disabled="@(!_canMarkAttendance)" />
                                                    </td>
                                                }
                                                <td style="text-align: center; color: #555;">@participant.TotalDays</td>
                                                <td style="text-align: center; color: #388e3c; font-weight: 600;">@participant.PresentDays</td>
                                                <td style="text-align: center;">
                                                    <MudChip T="string" Size="Size.Small"
                                                             Color="@(participant.AttendancePercentage >= 75 ? Color.Success : Color.Warning)">
                                                        @participant.AttendancePercentage.ToString("F1")%
                                                    </MudChip>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>
                </MudTabPanel>

                <!-- Tab 3: Results & Certificates -->
                <MudTabPanel Text="Results" Icon="@Icons.Material.Filled.EmojiEvents">
                    <div class="pa-4">
                        <div class="d-flex align-center justify-space-between mb-3">
                            <MudText Typo="Typo.h6" Style="color: #1a237e; font-weight: 600;">
                                Course Results & Certificates
                            </MudText>
                            <MudButton Variant="Variant.Outlined"
                                      Color="Color.Primary"
                                      Size="Size.Small"
                                      StartIcon="@Icons.Material.Filled.Refresh"
                                      OnClick="LoadResults">
                                Refresh
                            </MudButton>
                        </div>

                        @if (!IsCourseEnded())
                        {
                            <MudAlert Severity="Severity.Info" Dense="true" Class="mb-3">
                                Course is in progress. Results can be entered after the course ends on @_courseDetail?.EndDate.ToString("dd MMM yyyy").
                            </MudAlert>
                        }

                        @if (_loadingResults)
                        {
                            <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
                        }
                        else if (!_results.Any())
                        {
                            <div class="pa-4 text-center">
                                <MudIcon Icon="@Icons.Material.Filled.AssignmentLate" Size="Size.Large" Color="Color.Secondary" />
                                <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mt-2">
                                    No participants found. Please add participants first.
                                </MudText>
                            </div>
                        }
                        else
                        {
                            <MudTable Items="@_results" Hover="true" Dense="true" Striped="true">
                                <HeaderContent>
                                    <MudTh Style="background-color: #1a237e; color: white;">S.No</MudTh>
                                    <MudTh Style="background-color: #1a237e; color: white;">Employee Code</MudTh>
                                    <MudTh Style="background-color: #1a237e; color: white;">Participant Name</MudTh>
                                    <MudTh Style="background-color: #1a237e; color: white;">Department</MudTh>
                                    <MudTh Style="background-color: #1a237e; color: white; text-align: center;">Enrolled On</MudTh>
                                    <MudTh Style="background-color: #1a237e; color: white; text-align: center;">Course Start Date</MudTh>
                                    <MudTh Style="background-color: #1a237e; color: white; text-align: center;">Course End Date</MudTh>
                                    <MudTh Style="background-color: #1a237e; color: white; text-align: center;">Total Days</MudTh>
                                    <MudTh Style="background-color: #1a237e; color: white; text-align: center;">Present</MudTh>
                                    <MudTh Style="background-color: #1a237e; color: white; text-align: center;">Att. %</MudTh>
                                    <MudTh Style="background-color: #1a237e; color: white; text-align: center;">Marks</MudTh>
                                    <MudTh Style="background-color: #1a237e; color: white; text-align: center;">Status</MudTh>
                                    <MudTh Style="background-color: #1a237e; color: white; text-align: center;">Action</MudTh>
                                </HeaderContent>
                                <RowTemplate Context="result">
                                    @{
                                        var enrolledDate = _courseDetail?.Participants
                                            .FirstOrDefault(p => p.StaffId == result.StaffId)?.CreatedDate;
                                    }
                                    <MudTd DataLabel="S.No">@(_results.IndexOf(result) + 1)</MudTd>
                                    <MudTd DataLabel="Employee Code">@result.EmployeeCode</MudTd>
                                    <MudTd DataLabel="Participant Name">@result.StaffName</MudTd>
                                    <MudTd DataLabel="Department">@result.Department</MudTd>
                                    <MudTd DataLabel="Enrolled On" Style="text-align: center;">
                                        @(enrolledDate.HasValue ? enrolledDate.Value.ToString("dd MMM yyyy") : "-")
                                    </MudTd>
                                    <MudTd DataLabel="Course Start Date" Style="text-align: center;">@_courseDetail?.StartDate.ToString("dd-MM-yyyy")</MudTd>
                                    <MudTd DataLabel="Course End Date" Style="text-align: center;">@_courseDetail?.EndDate.ToString("dd-MM-yyyy")</MudTd>
                                    <MudTd DataLabel="Total Days" Style="text-align: center;">@result.TotalDays</MudTd>
                                    <MudTd DataLabel="Present" Style="text-align: center; color: #388e3c; font-weight: 600;">@result.PresentDays</MudTd>
                                    <MudTd DataLabel="Att. %" Style="text-align: center;">
                                        <MudChip T="string" Size="Size.Small"
                                                 Color="@(result.AttendancePercentage >= 75 ? Color.Success : Color.Warning)">
                                            @result.AttendancePercentage.ToString("F1")%
                                        </MudChip>
                                    </MudTd>
                                    <MudTd DataLabel="Marks" Style="text-align: center;">
                                        @if (_canEditResults && IsCourseEnded())
                                        {
                                            <MudNumericField T="decimal?"
                                                            Value="@result.Marks"
                                                            ValueChanged="@((decimal? val) => UpdateMarks(result.StaffId, val))"
                                                            Variant="Variant.Outlined"
                                                            Min="0"
                                                            Max="100"
                                                            Style="width: 80px;"
                                                            Margin="Margin.Dense" />
                                        }
                                        else
                                        {
                                            <MudText Typo="Typo.body2">@(result.Marks.HasValue ? result.Marks.Value.ToString("F1") : "-")</MudText>
                                        }
                                    </MudTd>
                                    <MudTd DataLabel="Status" Style="text-align: center;">
                                        @if (_canEditResults && IsCourseEnded())
                                        {
                                            <MudSwitch T="bool"
                                                      Value="@(result.ResultStatus == "Pass")"
                                                      ValueChanged="@((bool val) => UpdateResultStatus(result.StaffId, val))"
                                                      Color="Color.Success"
                                                      Size="Size.Small" />
                                        }
                                        @if (result.ResultStatus == "Pass")
                                        {
                                            <MudChip T="string" Size="Size.Small" Color="Color.Success">Pass</MudChip>
                                        }
                                        else if (result.ResultStatus == "Fail")
                                        {
                                            <MudChip T="string" Size="Size.Small" Color="Color.Error">Fail</MudChip>
                                        }
                                        else
                                        {
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">Pending</MudText>
                                        }
                                    </MudTd>
                                    <MudTd DataLabel="Action" Style="text-align: center;">
                                        @if (!string.IsNullOrEmpty(result.CertificatePath))
                                        {
                                            <MudTooltip Text="@($"Serial: {result.CertificateSerialNumber}")">
                                                <MudIconButton Icon="@Icons.Material.Filled.Visibility"
                                                              Size="Size.Small"
                                                              Color="Color.Primary"
                                                              OnClick="@(async () => await ViewCertificate(result))" />
                                            </MudTooltip>
                                        }
                                        else if (result.ResultStatus == "Pass" && _canEditResults)
                                        {
                                            <MudButton Variant="Variant.Text"
                                                      Color="Color.Primary"
                                                      Size="Size.Small"
                                                      StartIcon="@Icons.Material.Filled.Download"
                                                      OnClick="@(() => GenerateCertificate(result.StaffId))">
                                                Generate
                                            </MudButton>
                                        }
                                        else
                                        {
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">-</MudText>
                                        }
                                    </MudTd>
                                </RowTemplate>
                            </MudTable>
                        }
                    </div>
                </MudTabPanel>
            </MudTabs>
        </MudPaper>
    </MudContainer>
}

@code {
    [Parameter]
    public int CoursePlanId { get; set; }

    private CourseDetailWithParticipantsDto? _courseDetail;
    private List<StaffListDto> _availableStaff = new();
    private IEnumerable<int> _selectedStaffIds = new List<int>();
    private List<AttendanceGridDto> _attendanceGrid = new();
    private List<CourseResultDto> _results = new();
    private List<DateTime> _dateRange = new();

    private bool _isLoading = true;
    private bool _adding = false;
    private bool _loadingAttendance = false;
    private bool _loadingResults = false;
    private bool _savingAttendance = false;
    private bool _hasUnsavedChanges = false;
    private HashSet<(int StaffId, DateTime Date)> _pendingChanges = new();
    private int _activeTab = 0;
    private int _tenantId;
    private int _userId;
    private int _accessLevel = 0;
    private ClaimsPrincipal? _user;

    private bool _canMarkAttendance => _accessLevel >= 1;
    private bool _canEditResults    => _accessLevel >= 2;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        _user = authState.User;

        if (_user?.Identity?.IsAuthenticated ?? false)
        {
            var userIdClaim = _user.FindFirst(ClaimTypes.NameIdentifier)?.Value;
            var tenantIdClaim = _user.FindFirst("TenantId")?.Value;

            if (int.TryParse(userIdClaim, out var userId))
                _userId = userId;

            if (int.TryParse(tenantIdClaim, out var tenantId))
                _tenantId = tenantId;

        }

        await LoadCourseData();
        await LoadAvailableStaff();
        _accessLevel = await AuthorizationHelper.GetModuleAccessLevelAsync(_userId, "Course Management", _tenantId);
        // Pre-populate the attendance grid so the tab is ready without needing to click it first
        await LoadAttendanceGrid();
    }

    private async Task LoadCourseData()
    {
        try
        {
            _isLoading = true;
            _courseDetail = await ParticipantService.GetCourseWithParticipantsAsync(CoursePlanId, _tenantId);

            if (_courseDetail != null)
            {
                // Normalize to plain dates (Kind=Unspecified, time=midnight) so they
                // match the normalized keys in AttendanceGridDto.AttendanceByDate exactly.
                var startDate = new DateTime(_courseDetail.StartDate.Year, _courseDetail.StartDate.Month, _courseDetail.StartDate.Day);
                var endDate   = new DateTime(_courseDetail.EndDate.Year,   _courseDetail.EndDate.Month,   _courseDetail.EndDate.Day);
                _dateRange = Enumerable.Range(0, (endDate - startDate).Days + 1)
                    .Select(offset => startDate.AddDays(offset))
                    .ToList();
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading course data for CoursePlanId: {CoursePlanId}", CoursePlanId);
            Snackbar.Add("Error loading course data", Severity.Error);
        }
        finally
        {
            _isLoading = false;
