    private async Task ViewCertificate(CourseResultDto result)
    {
        if (!string.IsNullOrEmpty(result.CertificatePath))
        {
            try
            {
                // Open certificate in new tab using window.open
                var certificateUrl = result.CertificatePath.StartsWith("/")
                    ? result.CertificatePath
                    : "/" + result.CertificatePath;
                await JS.InvokeVoidAsync("window.open", certificateUrl, "_blank");
                Snackbar.Add($"Opening certificate (Serial: {result.CertificateSerialNumber})", Severity.Success);
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "Error opening certificate");
                Snackbar.Add("Error opening certificate", Severity.Error);
            }
        }
    }

    private bool IsCourseEnded()
    {
        if (_courseDetail == null)
            return false;

        return DateTime.Today > _courseDetail.EndDate;
    }

    private string GetStaffDisplayName(int staffId)
    {
        var staff = _availableStaff.FirstOrDefault(s => s.StaffId == staffId);
        if (staff != null)
        {
            return $"{staff.Name} ({staff.EmployeeCode})";
        }
        // Check in existing participants as well
        var participant = _courseDetail?.Participants?.FirstOrDefault(p => p.StaffId == staffId);
        if (participant != null)
        {
            return $"{participant.StaffName} ({participant.EmployeeCode})";
        }
        return staffId.ToString();
    }

