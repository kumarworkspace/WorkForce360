    private async Task LoadAttendanceGrid()
    {
        try
        {
            _loadingAttendance = true;
            StateHasChanged();

            _attendanceGrid = (await ParticipantService.GetAttendanceGridAsync(CoursePlanId, _tenantId)).ToList();

            // If the service returned nothing but participants are already loaded,
            // build a blank grid so the trainer can start marking attendance immediately.
            if (!_attendanceGrid.Any() && _courseDetail?.Participants.Any() == true)
            {
                _attendanceGrid = _courseDetail.Participants.Select(p => new AttendanceGridDto
                {
                    StaffId = p.StaffId,
                    StaffName = p.StaffName,
                    EmployeeCode = p.EmployeeCode,
                    AttendanceByDate = _dateRange.ToDictionary(d => d.ToString("yyyy-MM-dd"), _ => false),
                    TotalDays = _dateRange.Count,
                    PresentDays = 0,
                    AttendancePercentage = 0
                }).ToList();
            }

            // Reset pending changes when loading fresh data
            _pendingChanges.Clear();
            _hasUnsavedChanges = false;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading attendance grid");
            Snackbar.Add("Error loading attendance data", Severity.Error);
        }
        finally
        {
            _loadingAttendance = false;
        }
    }

    private void UpdateAttendance(int staffId, DateTime date, bool isPresent)
    {
        // Update local grid immediately for responsive UI
        var participant = _attendanceGrid.FirstOrDefault(p => p.StaffId == staffId);
        if (participant != null)
        {
            participant.AttendanceByDate[date.ToString("yyyy-MM-dd")] = isPresent;
            participant.PresentDays = participant.AttendanceByDate.Count(kvp => kvp.Value);
            participant.AttendancePercentage = participant.TotalDays > 0
                ? Math.Round((decimal)participant.PresentDays / participant.TotalDays * 100, 2)
                : 0;

            // Track pending changes
            _pendingChanges.Add((staffId, date));
            _hasUnsavedChanges = true;

            StateHasChanged();
        }
    }

    private bool? GetSelectAllState(DateTime date)
    {
        if (!_attendanceGrid.Any()) return false;
        var dateKey = date.ToString("yyyy-MM-dd");
        var states = _attendanceGrid.Select(p => p.AttendanceByDate.GetValueOrDefault(dateKey, false)).ToList();
        if (states.All(s => s)) return true;
        if (states.All(s => !s)) return false;
        return null; // indeterminate — some checked, some not
    }

    private void ToggleSelectAll(DateTime date, bool value)
    {
        var dateKey = date.ToString("yyyy-MM-dd");
        foreach (var participant in _attendanceGrid)
        {
            participant.AttendanceByDate[dateKey] = value;
            participant.PresentDays = participant.AttendanceByDate.Count(kvp => kvp.Value);
            participant.AttendancePercentage = participant.TotalDays > 0
                ? Math.Round((decimal)participant.PresentDays / participant.TotalDays * 100, 2)
                : 0;
            _pendingChanges.Add((participant.StaffId, date));
        }
        _hasUnsavedChanges = _pendingChanges.Any();
        StateHasChanged();
    }

    private async Task SaveCurrentAttendance()
    {
        if (!_attendanceGrid.Any() || !_dateRange.Any())
        {
            Snackbar.Add("No attendance data to save", Severity.Warning);
            return;
        }

        try
        {
            _savingAttendance = true;
            StateHasChanged();

            var successCount = 0;
            var failCount = 0;

            // Save all current attendance states for each date
            foreach (var date in _dateRange)
            {
                var attendanceItems = _attendanceGrid
                    .Select(p => new AttendanceItemRequest
                    {
                        StaffId = p.StaffId,
                        IsPresent = p.AttendanceByDate.GetValueOrDefault(date.ToString("yyyy-MM-dd"), false),
                        Remarks = null
                    })
                    .ToList();

                var bulkRequest = new BulkAttendanceDateWiseRequest
                {
                    CoursePlanId = CoursePlanId,
                    AttendanceDate = date,
                    AttendanceItems = attendanceItems
                };

                var result = await ParticipantService.BulkMarkAttendanceDateWiseSpAsync(bulkRequest, _tenantId, _userId);

                if (result.Success)
                {
                    successCount += attendanceItems.Count;
                }
                else
                {
                    failCount += attendanceItems.Count;
                    Logger.LogWarning("Failed to save attendance for date {Date}: {Message}", date, result.Message);
                }
            }

            if (failCount == 0)
            {
                Snackbar.Add($"Attendance saved successfully", Severity.Success);
                _pendingChanges.Clear();
                _hasUnsavedChanges = false;
                // Reload to reflect actual saved data
                await LoadAttendanceGrid();
            }
            else if (successCount > 0)
            {
                Snackbar.Add($"Partially saved: some records failed", Severity.Warning);
                await LoadAttendanceGrid();
            }
            else
            {
                Snackbar.Add("Failed to save attendance. Please check the logs for details.", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error saving attendance");
            Snackbar.Add("Error saving attendance", Severity.Error);
        }
        finally
        {
            _savingAttendance = false;
            StateHasChanged();
        }
    }

    private async Task SaveAllAttendance()
    {
        // Redirect to SaveCurrentAttendance which saves all current states
        await SaveCurrentAttendance();
    }

