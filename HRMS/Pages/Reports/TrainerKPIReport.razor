@page "/tms/reports/trainer-kpi"
@layout MainLayout
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using HRMS.Core.Application.Interfaces
@using HRMS.Core.Application.DTOs
@using ClosedXML.Excel
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject ITMSReportService ReportService
@inject IStaffService StaffService
@inject ISnackbar Snackbar
@inject IJSRuntime JSRuntime
@inject ILogger<TrainerKPIReport> Logger

<PageTitle>Trainer KPI Report</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="pa-4">
    <MudBreadcrumbs Items="_breadcrumbs" Class="mb-2 pa-0" />

    <div class="mb-4">
        <MudText Typo="Typo.h4" Style="font-weight:600; color:#1a237e;">Trainer KPI Report</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">Classes conducted and training hours per trainer</MudText>
    </div>

    <!-- Filters — auto-search on change -->
    <MudPaper Elevation="1" Class="pa-4 mb-4" Style="border-radius:12px;">
        <MudGrid Spacing="2" AlignItems="AlignItems.Center">
            <MudItem xs="12" sm="6" md="2">
                <MudSelect T="int?" Label="Year" Value="_filter.Year"
                           ValueChanged="@(v => OnFilterChanged(() => _filter.Year = v))"
                           Clearable="true" Variant="Variant.Outlined" Margin="Margin.Dense">
                    @foreach (var y in _years)
                    {
                        <MudSelectItem T="int?" Value="(int?)y">@y</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="6" md="2">
                <MudSelect T="int?" Label="Month" Value="_filter.Month"
                           ValueChanged="@(v => OnFilterChanged(() => _filter.Month = v))"
                           Clearable="true" Variant="Variant.Outlined" Margin="Margin.Dense">
                    @foreach (var m in _months)
                    {
                        <MudSelectItem T="int?" Value="(int?)m.Num">@m.Name</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="6" md="2">
                <MudDatePicker Label="From Date" Date="_fromDate"
                               DateChanged="@(d => OnFilterChanged(() => _fromDate = d))"
                               Clearable="true" DateFormat="dd-MM-yyyy"
                               Variant="Variant.Outlined" Margin="Margin.Dense" />
            </MudItem>
            <MudItem xs="12" sm="6" md="2">
                <MudDatePicker Label="To Date" Date="_toDate"
                               DateChanged="@(d => OnFilterChanged(() => _toDate = d))"
                               Clearable="true" DateFormat="dd-MM-yyyy"
                               Variant="Variant.Outlined" Margin="Margin.Dense" />
            </MudItem>
            <MudItem xs="12" sm="6" md="2">
                <MudSelect T="int?" Label="Trainer" Value="_filter.TrainerId"
                           ValueChanged="@(v => OnFilterChanged(() => _filter.TrainerId = v))"
                           Clearable="true" Variant="Variant.Outlined" Margin="Margin.Dense">
                    @foreach (var t in _trainers)
                    {
                        <MudSelectItem T="int?" Value="(int?)t.StaffId">@t.Name</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="2" Class="d-flex justify-end">
                <MudButton Variant="Variant.Outlined" OnClick="ClearFilters" Size="Size.Small">Clear</MudButton>
            </MudItem>
        </MudGrid>
    </MudPaper>

    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" Class="mb-4" />
    }
    else
    {
        <!-- Summary Cards -->
        <MudGrid Spacing="3" Class="mb-4">
            <MudItem xs="12" sm="6">
                <MudPaper Elevation="2" Class="pa-4" Style="background:linear-gradient(135deg,#667eea,#764ba2);color:white;border-radius:12px;">
                    <div class="d-flex align-center justify-space-between">
                        <div>
                            <MudText Typo="Typo.h3" Style="font-weight:bold;">@_result.Summary.TotalClasses</MudText>
                            <MudText Typo="Typo.body2" Style="opacity:.9;">Total Classes Conducted</MudText>
                        </div>
                        <MudIcon Icon="@Icons.Material.Filled.EventNote" Size="Size.Large" Style="opacity:.8;" />
                    </div>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudPaper Elevation="2" Class="pa-4" Style="background:linear-gradient(135deg,#4facfe,#00f2fe);color:white;border-radius:12px;">
                    <div class="d-flex align-center justify-space-between">
                        <div>
                            <MudText Typo="Typo.h3" Style="font-weight:bold;">@_result.Summary.TotalHours.ToString("F2")</MudText>
                            <MudText Typo="Typo.body2" Style="opacity:.9;">Total Training Hours</MudText>
                        </div>
                        <MudIcon Icon="@Icons.Material.Filled.Schedule" Size="Size.Large" Style="opacity:.8;" />
                    </div>
                </MudPaper>
            </MudItem>
        </MudGrid>

        <!-- Table -->
        <MudPaper Elevation="2" Class="pa-4" Style="border-radius:12px;">
            <div class="d-flex align-center justify-space-between mb-3">
                <MudText Typo="Typo.h6" Style="font-weight:600;">Trainer KPI Details</MudText>
                <MudButton Variant="Variant.Filled" Color="Color.Success"
                           StartIcon="@Icons.Material.Filled.Download"
                           OnClick="ExportExcel" Disabled="@(!_result.Rows.Any())">
                    Export Report
                </MudButton>
            </div>

            @if (!_result.Rows.Any())
            {
                <MudAlert Severity="Severity.Info">No data found for the selected filters.</MudAlert>
            }
            else
            {
                <MudTable Items="_result.Rows" Hover="true" Dense="true" Striped="true"
                          Elevation="0" FixedHeader="true" Height="500px">
                    <HeaderContent>
                        <MudTh Style="background:#e3f2fd;">S.No</MudTh>
                        <MudTh Style="background:#e3f2fd;">Trainer Name</MudTh>
                        <MudTh Style="background:#e3f2fd;">Employee Code</MudTh>
                        <MudTh Style="background:#e3f2fd;">Department</MudTh>
                        <MudTh Style="background:#e3f2fd;">Period</MudTh>
                        <MudTh Style="background:#e3f2fd; text-align:right;">No. of Classes</MudTh>
                        <MudTh Style="background:#e3f2fd; text-align:right;">Total Hours</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>@context.RowNo</MudTd>
                        <MudTd><MudText Style="font-weight:500;">@context.TrainerName</MudText></MudTd>
                        <MudTd>@(context.EmployeeCode ?? "—")</MudTd>
                        <MudTd>@(context.Department ?? "—")</MudTd>
                        <MudTd>@context.MonthName</MudTd>
                        <MudTd Style="text-align:right; font-weight:600; color:#1a237e;">@context.NumClasses</MudTd>
                        <MudTd Style="text-align:right; font-weight:600; color:#0d47a1;">@context.TotalHours.ToString("F2")</MudTd>
                    </RowTemplate>
                </MudTable>

                <!-- Pagination -->
                <div class="d-flex align-center justify-space-between mt-3">
                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                        Showing @((_currentPage - 1) * _pageSize + 1)–@(Math.Min(_currentPage * _pageSize, (int)_result.TotalCount)) of @_result.TotalCount records
                    </MudText>
                    <MudPagination Count="@_totalPages" Selected="_currentPage"
                                   SelectedChanged="OnPageChanged" Color="Color.Primary" />
                </div>
            }
        </MudPaper>
    }
</MudContainer>

@code {
    private int _tenantId;
    private bool _loading = true;
    private int _currentPage = 1;
    private int _pageSize = 20;
    private int _totalPages = 1;

    private DateTime? _fromDate;
    private DateTime? _toDate;
    private TrainerKPIFilter _filter = new();
    private TrainerKPIResultDto _result = new();

    private List<StaffListDto> _trainers = new();
    private System.Threading.CancellationTokenSource? _debounce;

    private static readonly List<int> _years =
        Enumerable.Range(DateTime.Today.Year - 4, 5).OrderByDescending(y => y).ToList();

    private static readonly List<(int Num, string Name)> _months =
    [
        (1,"January"),(2,"February"),(3,"March"),(4,"April"),
        (5,"May"),(6,"June"),(7,"July"),(8,"August"),
        (9,"September"),(10,"October"),(11,"November"),(12,"December")
    ];

    private readonly List<BreadcrumbItem> _breadcrumbs =
    [
        new("Home", "/dashboard", icon: Icons.Material.Filled.Home),
        new("Reports", null, disabled: true),
        new("Trainer KPI Report", null, disabled: true)
    ];

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        _tenantId = int.TryParse(auth.User.FindFirst("TenantId")?.Value, out var tid) ? tid : 0;
        _filter.Year = DateTime.Today.Year;

        await Task.WhenAll(LoadDropdowns(), LoadReport());
    }

    private async Task LoadDropdowns()
    {
        try
        {
            var trainers = await StaffService.GetPagedAsync(_tenantId, 1, 1000, null, null, null);
            _trainers = trainers.Items.Where(s => s.IsActive).ToList();
        }
        catch (Exception ex) { Logger.LogError(ex, "Error loading trainers"); }
    }

    private async Task OnFilterChanged(Action setter)
    {
        setter();
        _currentPage = 1;
        _debounce?.Cancel();
        _debounce = new System.Threading.CancellationTokenSource();
        var token = _debounce.Token;
        try
        {
            await Task.Delay(400, token);
            await LoadReport();
        }
        catch (TaskCanceledException) { }
    }

    private async Task LoadReport()
    {
        _loading = true;
        StateHasChanged();
        try
        {
            _filter.TenantId   = _tenantId;
            _filter.FromDate   = _fromDate;
            _filter.ToDate     = _toDate;
            _filter.PageNumber = _currentPage;
            _filter.PageSize   = _pageSize;

            _result     = await ReportService.GetTrainerKPIReportAsync(_filter);
            _totalPages = (int)Math.Ceiling(_result.TotalCount / (double)_pageSize);
            if (_totalPages < 1) _totalPages = 1;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading Trainer KPI Report");
            Snackbar.Add("Failed to load report.", Severity.Error);
        }
        finally { _loading = false; }
    }

    private async Task OnPageChanged(int page)
    {
        _currentPage = page;
        await LoadReport();
    }

    private async Task ClearFilters()
    {
        _filter      = new TrainerKPIFilter { Year = DateTime.Today.Year };
        _fromDate    = null;
        _toDate      = null;
        _currentPage = 1;
        await LoadReport();
    }

    private async Task ExportExcel()
    {
        try
        {
            var exportFilter = new TrainerKPIFilter
            {
                TenantId   = _tenantId,
                Year       = _filter.Year,
                Month      = _filter.Month,
                FromDate   = _filter.FromDate,
                ToDate     = _filter.ToDate,
                TrainerId  = _filter.TrainerId,
                PageNumber = 1,
                PageSize   = 100000
            };
            var exportData = await ReportService.GetTrainerKPIReportAsync(exportFilter);

            using var wb = new XLWorkbook();
            var ws = wb.Worksheets.Add("Trainer KPI");

            var headers = new[] { "S.No", "Trainer Name", "Employee Code", "Department", "Period", "No. of Classes", "Total Hours" };
            for (int i = 0; i < headers.Length; i++)
            {
                var cell = ws.Cell(1, i + 1);
                cell.Value = headers[i];
                cell.Style.Font.Bold = true;
                cell.Style.Fill.BackgroundColor = XLColor.FromHtml("#1a237e");
                cell.Style.Font.FontColor = XLColor.White;
            }

            // Summary
            ws.Cell(2, 1).Value = $"Total Classes: {exportData.Summary.TotalClasses}   Total Hours: {exportData.Summary.TotalHours:F2}";
            ws.Range(2, 1, 2, headers.Length).Merge();
            ws.Cell(2, 1).Style.Font.Italic = true;
            ws.Cell(2, 1).Style.Fill.BackgroundColor = XLColor.LightYellow;

            int row = 3;
            foreach (var r in exportData.Rows)
            {
                ws.Cell(row, 1).Value = (int)r.RowNo;
                ws.Cell(row, 2).Value = r.TrainerName;
                ws.Cell(row, 3).Value = r.EmployeeCode ?? "";
                ws.Cell(row, 4).Value = r.Department ?? "";
                ws.Cell(row, 5).Value = r.MonthName;
                ws.Cell(row, 6).Value = (long)r.NumClasses;
                ws.Cell(row, 7).Value = (double)r.TotalHours;
                row++;
            }
            ws.Columns().AdjustToContents();

            using var ms = new MemoryStream();
            wb.SaveAs(ms);
            var base64 = Convert.ToBase64String(ms.ToArray());
            await JSRuntime.InvokeVoidAsync("downloadFileFromBase64", base64,
                "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
                $"TrainerKPI_{DateTime.Today:yyyyMMdd}.xlsx");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error exporting Trainer KPI");
            Snackbar.Add("Export failed.", Severity.Error);
        }
    }
}
