@page "/tms/reports/general"
@layout MainLayout
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using HRMS.Core.Application.Interfaces
@using HRMS.Core.Application.DTOs
@using ClosedXML.Excel
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject ITMSReportService ReportService
@inject ICourseRegistrationService CourseService
@inject IStaffService StaffService
@inject ISnackbar Snackbar
@inject IJSRuntime JSRuntime
@inject ILogger<GeneralReport> Logger

<PageTitle>General Report</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="pa-4">
    <MudBreadcrumbs Items="_breadcrumbs" Class="mb-2 pa-0" />

    <div class="mb-4">
        <MudText Typo="Typo.h4" Style="font-weight:600; color:#1a237e;">General Report</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">Course session summary with attendance details</MudText>
    </div>

    <!-- Filters — auto-search on change -->
    <MudPaper Elevation="1" Class="pa-4 mb-4" Style="border-radius:12px;">
        <MudGrid Spacing="2" AlignItems="AlignItems.Center">
            <MudItem xs="12" sm="6" md="3">
                <MudSelect T="int?" Label="Select Course" Value="_filter.CourseId"
                           ValueChanged="@(v => OnFilterChanged(() => _filter.CourseId = v))"
                           Clearable="true" Variant="Variant.Outlined" Margin="Margin.Dense">
                    @foreach (var c in _courses)
                    {
                        <MudSelectItem T="int?" Value="(int?)c.CourseId">@c.Title</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudSelect T="int?" Label="Select Trainer" Value="_filter.TrainerId"
                           ValueChanged="@(v => OnFilterChanged(() => _filter.TrainerId = v))"
                           Clearable="true" Variant="Variant.Outlined" Margin="Margin.Dense">
                    @foreach (var t in _trainers)
                    {
                        <MudSelectItem T="int?" Value="(int?)t.StaffId">@t.Name</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="6" md="2">
                <MudDatePicker Label="Start Date" Date="_fromDate"
                               DateChanged="@(d => OnFilterChanged(() => _fromDate = d))"
                               Clearable="true" DateFormat="dd-MM-yyyy"
                               Variant="Variant.Outlined" Margin="Margin.Dense" />
            </MudItem>
            <MudItem xs="12" sm="6" md="2">
                <MudDatePicker Label="To Date" Date="_toDate"
                               DateChanged="@(d => OnFilterChanged(() => _toDate = d))"
                               Clearable="true" DateFormat="dd-MM-yyyy"
                               Variant="Variant.Outlined" Margin="Margin.Dense" />
            </MudItem>
            <MudItem xs="12" md="2" Class="d-flex justify-end">
                <MudButton Variant="Variant.Outlined" OnClick="ClearFilters" Size="Size.Small">Clear</MudButton>
            </MudItem>
        </MudGrid>
    </MudPaper>

    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" Class="mb-4" />
    }
    else
    {
        <!-- Summary Cards -->
        <MudGrid Spacing="3" Class="mb-4">
            <MudItem xs="12" sm="4">
                <MudPaper Elevation="2" Class="pa-4" Style="background:#fdf3dc; border-radius:12px; text-align:center;">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Number of Classes</MudText>
                    <MudText Typo="Typo.h4" Style="font-weight:bold; color:#b8860b;">@_result.Summary.TotalClasses</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudPaper Elevation="2" Class="pa-4" Style="background:#dff0d8; border-radius:12px; text-align:center;">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Total Staff Attended</MudText>
                    <MudText Typo="Typo.h4" Style="font-weight:bold; color:#2e7d32;">@_result.Summary.TotalStaffAttended</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudPaper Elevation="2" Class="pa-4" Style="background:#d0e8f5; border-radius:12px; text-align:center;">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Total Hours</MudText>
                    <MudText Typo="Typo.h4" Style="font-weight:bold; color:#0d47a1;">@_result.Summary.TotalHours.ToString("F2")</MudText>
                </MudPaper>
            </MudItem>
        </MudGrid>

        <!-- Table -->
        <MudPaper Elevation="2" Class="pa-4" Style="border-radius:12px;">
            <div class="d-flex align-center justify-space-between mb-3">
                <MudText Typo="Typo.h6" Style="font-weight:600;">
                    Summary Report
                    <MudChip T="string" Size="Size.Small" Color="Color.Primary" Class="ml-2">@_result.TotalCount records</MudChip>
                </MudText>
                <MudButton Variant="Variant.Filled" Color="Color.Success"
                           StartIcon="@Icons.Material.Filled.Download"
                           OnClick="ExportExcel" Disabled="@(!_result.Rows.Any())">
                    Export Report
                </MudButton>
            </div>

            @if (!_result.Rows.Any())
            {
                <MudAlert Severity="Severity.Info">No data found for the selected filters.</MudAlert>
            }
            else
            {
                <MudTable Items="_result.Rows" Hover="true" Dense="true" Striped="true"
                          Elevation="0" FixedHeader="true" Height="500px">
                    <HeaderContent>
                        <MudTh Style="background:#e3f2fd;">S.No</MudTh>
                        <MudTh Style="background:#e3f2fd;">Start Date</MudTh>
                        <MudTh Style="background:#e3f2fd;">End Date</MudTh>
                        <MudTh Style="background:#e3f2fd;">Time</MudTh>
                        <MudTh Style="background:#e3f2fd;">Title</MudTh>
                        <MudTh Style="background:#e3f2fd;">Type</MudTh>
                        <MudTh Style="background:#e3f2fd;">Total Hours</MudTh>
                        <MudTh Style="background:#e3f2fd;">Trainer</MudTh>
                        <MudTh Style="background:#e3f2fd;">Venue</MudTh>
                        <MudTh Style="background:#e3f2fd; text-align:right;">Total Staff Attended</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>@context.RowNo</MudTd>
                        <MudTd>@context.StartDate.ToString("dd-MM-yyyy")</MudTd>
                        <MudTd>@context.EndDate.ToString("dd-MM-yyyy")</MudTd>
                        <MudTd>@context.TimeRange</MudTd>
                        <MudTd><MudText Style="color:#1565c0; font-weight:500;">@context.Title</MudText></MudTd>
                        <MudTd>
                            <MudChip T="string" Size="Size.Small" Color="@GetTypeColor(context.CourseType)">
                                @(context.CourseType ?? "—")
                            </MudChip>
                        </MudTd>
                        <MudTd>@context.TotalHours.ToString("F0") Hrs</MudTd>
                        <MudTd>@context.TrainerName</MudTd>
                        <MudTd>@(context.Venue ?? "—")</MudTd>
                        <MudTd Style="text-align:right; font-weight:600;">@context.TotalStaffAttended</MudTd>
                    </RowTemplate>
                </MudTable>

                <div class="d-flex align-center justify-space-between mt-3">
                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                        @((_currentPage - 1) * _pageSize + 1)–@(Math.Min(_currentPage * _pageSize, (int)_result.TotalCount)) of @_result.TotalCount
                    </MudText>
                    <MudPagination Count="@_totalPages" Selected="_currentPage"
                                   SelectedChanged="OnPageChanged" Color="Color.Primary" />
                </div>
            }
        </MudPaper>
    }
</MudContainer>

@code {
    private int _tenantId;
    private bool _loading = true;
    private int _currentPage = 1;
    private readonly int _pageSize = 20;
    private int _totalPages = 1;

    private DateTime? _fromDate;
    private DateTime? _toDate;
    private GeneralReportFilter _filter = new();
    private GeneralReportResultDto _result = new();

    private List<CourseListDto> _courses = new();
    private List<StaffListDto> _trainers = new();

    private System.Threading.CancellationTokenSource? _debounce;

    private readonly List<BreadcrumbItem> _breadcrumbs =
    [
        new("Home", "/dashboard", icon: Icons.Material.Filled.Home),
        new("Reports", null, disabled: true),
        new("General Report", null, disabled: true)
    ];

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        _tenantId = int.TryParse(auth.User.FindFirst("TenantId")?.Value, out var tid) ? tid : 0;
        _fromDate = new DateTime(DateTime.Today.Year, 1, 1);
        _toDate   = DateTime.Today;
        await Task.WhenAll(LoadDropdowns(), LoadReport());
    }

    private async Task LoadDropdowns()
    {
        try
        {
            var courses  = await CourseService.GetPagedAsync(_tenantId, 1, 1000);
            var trainers = await StaffService.GetPagedAsync(_tenantId, 1, 1000, null, null, null);
            _courses  = courses.Items.Where(c => c.IsActive).ToList();
            _trainers = trainers.Items.Where(s => s.IsActive).ToList();
        }
        catch (Exception ex) { Logger.LogError(ex, "Error loading dropdowns"); }
    }

    private async Task OnFilterChanged(Action setter)
    {
        setter();
        _currentPage = 1;
        _debounce?.Cancel();
        _debounce = new System.Threading.CancellationTokenSource();
        var token = _debounce.Token;
        try
        {
            await Task.Delay(400, token);
            await LoadReport();
        }
        catch (TaskCanceledException) { }
    }

    private async Task LoadReport()
    {
        _loading = true;
        StateHasChanged();
        try
        {
            _filter.TenantId   = _tenantId;
            _filter.FromDate   = _fromDate;
            _filter.ToDate     = _toDate;
            _filter.PageNumber = _currentPage;
            _filter.PageSize   = _pageSize;

            _result     = await ReportService.GetGeneralReportAsync(_filter);
            _totalPages = (int)Math.Ceiling(_result.TotalCount / (double)_pageSize);
            if (_totalPages < 1) _totalPages = 1;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading General Report");
            Snackbar.Add("Failed to load report.", Severity.Error);
        }
        finally { _loading = false; }
    }

    private async Task OnPageChanged(int page)
    {
        _currentPage = page;
        await LoadReport();
    }

    private async Task ClearFilters()
    {
        _filter      = new GeneralReportFilter();
        _fromDate    = new DateTime(DateTime.Today.Year, 1, 1);
        _toDate      = DateTime.Today;
        _currentPage = 1;
        await LoadReport();
    }

    private Color GetTypeColor(string? type) => type?.ToLower() switch
    {
        "initial"   => Color.Info,
        "recurrent" => Color.Warning,
        _           => Color.Default
    };

    private async Task ExportExcel()
    {
        try
        {
            var exportData = await ReportService.GetGeneralReportAsync(new GeneralReportFilter
            {
                TenantId = _tenantId, FromDate = _filter.FromDate, ToDate = _filter.ToDate,
                CourseId = _filter.CourseId, TrainerId = _filter.TrainerId,
                Department = _filter.Department, Company = _filter.Company,
                PageNumber = 1, PageSize = 100000
            });

            using var wb = new XLWorkbook();
            var ws = wb.Worksheets.Add("General Report");
            var headers = new[] { "S.No","Start Date","End Date","Time","Title","Type","Total Hours","Trainer","Venue","Total Staff Attended" };
            for (int i = 0; i < headers.Length; i++)
            {
                var cell = ws.Cell(1, i + 1);
                cell.Value = headers[i];
                cell.Style.Font.Bold = true;
                cell.Style.Fill.BackgroundColor = XLColor.FromHtml("#1a237e");
                cell.Style.Font.FontColor = XLColor.White;
            }
            ws.Cell(2, 1).Value = $"Classes: {exportData.Summary.TotalClasses}   Staff Attended: {exportData.Summary.TotalStaffAttended}   Total Hours: {exportData.Summary.TotalHours:F2}";
            ws.Range(2, 1, 2, headers.Length).Merge();
            ws.Cell(2, 1).Style.Font.Italic = true;
            ws.Cell(2, 1).Style.Fill.BackgroundColor = XLColor.LightYellow;

            int row = 3;
            foreach (var r in exportData.Rows)
            {
                ws.Cell(row, 1).Value  = (int)r.RowNo;
                ws.Cell(row, 2).Value  = r.StartDate.ToString("dd-MM-yyyy");
                ws.Cell(row, 3).Value  = r.EndDate.ToString("dd-MM-yyyy");
                ws.Cell(row, 4).Value  = r.TimeRange;
                ws.Cell(row, 5).Value  = r.Title;
                ws.Cell(row, 6).Value  = r.CourseType ?? "";
                ws.Cell(row, 7).Value  = (double)r.TotalHours;
                ws.Cell(row, 8).Value  = r.TrainerName;
                ws.Cell(row, 9).Value  = r.Venue ?? "";
                ws.Cell(row, 10).Value = (long)r.TotalStaffAttended;
                row++;
            }
            ws.Columns().AdjustToContents();

            using var ms = new MemoryStream();
            wb.SaveAs(ms);
            await JSRuntime.InvokeVoidAsync("downloadFileFromBase64",
                Convert.ToBase64String(ms.ToArray()),
                "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
                $"GeneralReport_{DateTime.Today:yyyyMMdd}.xlsx");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error exporting");
            Snackbar.Add("Export failed.", Severity.Error);
        }
    }
}
