@page "/admin/create-user"
@page "/admin/create-user/{UserId:int}"
@layout MainLayout
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using HRMS.Core.Application.Interfaces
@using HRMS.Core.Application.DTOs
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IUserService UserService
@inject IStaffService StaffService
@inject IRoleService RoleService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject IHttpContextAccessor HttpContextAccessor
@implements IDisposable

<PageTitle>@(_isEditMode ? "Edit User" : "Create User")</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="pa-4">
    <div class="d-flex align-center justify-space-between mb-4">
        <div>
            <MudText Typo="Typo.h4" Style="font-weight: 600; color: #1a237e; margin-bottom: 4px;">@(_isEditMode ? "Edit User Account" : "Create User Account")</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">@(_isEditMode ? "Update user role" : "Create user accounts for staff members")</MudText>
        </div>
        <MudButton Variant="Variant.Text" StartIcon="@Icons.Material.Filled.ArrowBack" OnClick="NavigateBack">
            Back
        </MudButton>
    </div>

    <MudPaper Elevation="2" Class="pa-4" Style="border-radius: 8px;">
        <MudForm @ref="form" @bind-IsValid="@isValid">
            <MudGrid Spacing="3">
                @if (_isEditMode)
                {
                    <!-- Edit Mode: Show user info read-only -->
                    <MudItem xs="12">
                        <MudPaper Elevation="0" Class="pa-3" Style="background-color: #f5f5f5; border-radius: 4px;">
                            <MudText Typo="Typo.body2" Style="font-weight: 500;">Current User Information:</MudText>
                            <MudText Typo="Typo.body2">Name: <strong>@_existingUser?.FullName</strong></MudText>
                            <MudText Typo="Typo.body2">Email: <strong>@_existingUser?.Email</strong></MudText>
                            <MudText Typo="Typo.body2">Current Role: <strong>@_existingUser?.Role</strong></MudText>
                        </MudPaper>
                    </MudItem>

                    <!-- Role Selection (only editable field in edit mode) -->
                    <MudItem xs="12">
                        <MudSelect @bind-Value="@selectedRole"
                                  Label="Role *"
                                  Variant="Variant.Outlined"
                                  T="string"
                                  Required="true"
                                  RequiredError="Please select a role">
                            @foreach (var role in _roles)
                            {
                                <MudSelectItem Value="@role.RoleName">@role.RoleName</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                }
                else
                {
                    <!-- Create Mode -->
                    <!-- Staff Selection -->
                    <MudItem xs="12">
                        <MudAutocomplete T="StaffListDto"
                                       Value="@selectedStaff"
                                       ValueChanged="OnStaffSelected"
                                       SearchFunc="@SearchStaff"
                                       Label="Select Staff *"
                                       Variant="Variant.Outlined"
                                       ToStringFunc="@(staff => staff != null ? $"{staff.Name} ({staff.Email}) - {staff.Department}" : string.Empty)"
                                       ResetValueOnEmptyText="true"
                                       Required="true"
                                       RequiredError="Please select a staff member"
                                       ReadOnly="@_isEditMode">
                            <ItemTemplate>
                                <div style="padding: 8px;">
                                    <MudText Typo="Typo.body1" Style="font-weight: 500;">@context.Name</MudText>
                                    <MudText Typo="Typo.body2" Color="Color.Secondary">@context.Email - @context.Department</MudText>
                                </div>
                            </ItemTemplate>
                        </MudAutocomplete>
                    </MudItem>

                    @if (selectedStaff != null)
                    {
                        <!-- Email (read-only, auto-filled) -->
                        <MudItem xs="12">
                            <MudTextField @bind-Value="@email"
                                        Label="Email *"
                                        Variant="Variant.Outlined"
                                        Required="true"
                                        RequiredError="Email is required"
                                        HelperText="Email will be used for login"
                                        InputType="InputType.Email"
                                        ReadOnly="true" />
                        </MudItem>

                        <!-- Role Selection -->
                        <MudItem xs="12">
                            <MudSelect @bind-Value="@selectedRole"
                                      Label="Role *"
                                      Variant="Variant.Outlined"
                                      T="string"
                                      Required="true"
                                      RequiredError="Please select a role">
                                @foreach (var role in _roles)
                                {
                                    <MudSelectItem Value="@role.RoleName">@role.RoleName</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>

                        <!-- Password Options -->
                        <MudItem xs="12">
                            <MudSwitch T="bool" @bind-Checked="@autoGeneratePassword" 
                                      Label="Auto-generate password"
                                      Color="Color.Primary" />
                        </MudItem>

                        @if (!autoGeneratePassword)
                        {
                            <MudItem xs="12">
                                <MudTextField @bind-Value="@password"
                                            Label="Password *"
                                            Variant="Variant.Outlined"
                                            InputType="@passwordInputType"
                                            Required="true"
                                            RequiredError="Password is required"
                                            HelperText="Minimum 8 characters, must contain uppercase, lowercase, number, and special character"
                                            Adornment="Adornment.End"
                                            AdornmentIcon="@passwordIcon"
                                            OnAdornmentClick="TogglePasswordVisibility">
                                    <HelperText>
                                        <MudText Typo="Typo.caption">Password must be at least 8 characters and contain uppercase, lowercase, number, and special character</MudText>
                                    </HelperText>
                                </MudTextField>
                            </MudItem>
                        }
                        else
                        {
                            <MudItem xs="12">
                                <MudAlert Severity="Severity.Info">
                                    A random password will be generated and displayed after user creation.
                                </MudAlert>
                            </MudItem>
                        }

                        <!-- Staff Info Display -->
                        <MudItem xs="12">
                            <MudPaper Elevation="0" Class="pa-3" Style="background-color: #f5f5f5; border-radius: 4px;">
                                <MudText Typo="Typo.body2" Style="font-weight: 500;">Staff Information:</MudText>
                                <MudText Typo="Typo.body2">Name: <strong>@selectedStaff.Name</strong></MudText>
                                <MudText Typo="Typo.body2">Email: <strong>@selectedStaff.Email</strong></MudText>
                                <MudText Typo="Typo.body2">Department: <strong>@selectedStaff.Department</strong></MudText>
                                <MudText Typo="Typo.body2">Position: <strong>@selectedStaff.Position</strong></MudText>
                            </MudPaper>
                        </MudItem>
                    }
                }

                <!-- Action Buttons -->
                <MudItem xs="12">
                    <MudStack Row="true" Justify="Justify.FlexEnd" Spacing="2">
                        <MudButton Variant="Variant.Outlined" Color="Color.Default" OnClick="NavigateBack">
                            Cancel
                        </MudButton>
                        <MudButton Variant="Variant.Filled" 
                                 Color="Color.Primary" 
                                 OnClick="@(_isEditMode ? EventCallback.Factory.Create(this, UpdateUserAccount) : EventCallback.Factory.Create(this, CreateUserAccount))"
                                 Disabled="@(isCreating || !isValid)">
                            @if (isCreating)
                            {
                                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                            }
                            @(_isEditMode ? "Update User" : "Create User")
                        </MudButton>
                    </MudStack>
                </MudItem>
            </MudGrid>
        </MudForm>
    </MudPaper>
</MudContainer>

@code {
    private MudForm? form;
    private bool isValid = false;
    private bool isCreating = false;
    private StaffListDto? selectedStaff;
    private int? selectedStaffId;
    private string email = string.Empty;
    private string selectedRole = string.Empty;
    private string password = string.Empty;
    private bool autoGeneratePassword = false;
    private InputType passwordInputType = InputType.Password;
    private string passwordIcon = Icons.Material.Filled.VisibilityOff;

    private List<StaffListDto> _staffList = new();
    private List<RoleDto> _roles = new();
    private int _tenantId = 0;
    private int _userId = 0;
    private bool _isEditMode = false;
    private int? _editUserId;
    private UserListDto? _existingUser;

    [Parameter]
    public int? UserId { get; set; }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity?.IsAuthenticated == true)
        {
            var tenantIdClaim = user.FindFirst("TenantId")?.Value;
            var userIdClaim = user.FindFirst("UserId")?.Value;

            if (int.TryParse(tenantIdClaim, out var tid))
                _tenantId = tid;
            if (int.TryParse(userIdClaim, out var uid))
                _userId = uid;

            await LoadRoles();

            // Check if we're in edit mode
            var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
            var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);
            if (query.TryGetValue("userId", out var userIdValue) && int.TryParse(userIdValue, out var uidParam))
            {
                _editUserId = uidParam;
                _isEditMode = true;
                await LoadUserForEdit();
            }
            else if (UserId.HasValue)
            {
                _editUserId = UserId.Value;
                _isEditMode = true;
                await LoadUserForEdit();
            }
            else
            {
                await LoadAllStaff();
            }
        }
    }

    private async Task LoadRoles()
    {
        try
        {
            var roles = await RoleService.GetByTenantIdAsync(_tenantId);
            _roles = roles.Where(r => r.IsActive).OrderBy(r => r.RoleName).ToList();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading roles: {ex.Message}", Severity.Warning);
        }
    }

    private async Task LoadUserForEdit()
    {
        if (!_editUserId.HasValue) return;

        try
        {
            _existingUser = await UserService.GetByIdAsync(_editUserId.Value, _tenantId);
            if (_existingUser == null)
            {
                Snackbar.Add("User not found", Severity.Error);
                Navigation.NavigateTo("/admin/users");
                return;
            }

            selectedRole = _existingUser.Role;
            email = _existingUser.Email;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading user: {ex.Message}", Severity.Error);
            Navigation.NavigateTo("/admin/users");
        }
    }

    private async Task LoadAllStaff()
    {
        try
        {
            // Load ALL staff for the tenant (not just those without accounts)
            var pagedResult = await StaffService.GetPagedAsync(_tenantId, 1, 10000, null, null, null);
            _staffList = pagedResult.Items
                .Where(s => s.IsActive && !string.IsNullOrEmpty(s.Email))
                .OrderBy(s => s.Name)
                .ToList();
        }
        catch (Exception ex)
        {
            var errorMessage = ex.InnerException?.Message ?? ex.Message;
            Snackbar.Add($"Error loading staff: {errorMessage}", Severity.Error);
            _staffList = new List<StaffListDto>();
        }
    }

    private async Task<IEnumerable<StaffListDto>> SearchStaff(string value, CancellationToken cancellationToken)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return _staffList.Take(50);
        }
        
        var searchLower = value.ToLower();
        return _staffList.Where(s => 
            (s.Name?.ToLower().Contains(searchLower) ?? false) ||
            (s.Email?.ToLower().Contains(searchLower) ?? false) ||
            (s.Department?.ToLower().Contains(searchLower) ?? false)
        ).Take(50);
    }

    private void OnStaffSelected(StaffListDto? staff)
    {
        selectedStaff = staff;
        selectedStaffId = staff?.StaffId;
        
        if (staff != null)
        {
            // Auto-fill email from staff record
            if (!string.IsNullOrEmpty(staff.Email))
            {
                email = staff.Email;
            }
            StateHasChanged(); // Refresh UI to show auto-filled email
        }
        else
        {
            email = string.Empty; // Clear email if no staff selected
        }
    }

    private void TogglePasswordVisibility()
    {
        if (passwordInputType == InputType.Password)
        {
            passwordInputType = InputType.Text;
            passwordIcon = Icons.Material.Filled.Visibility;
        }
        else
        {
            passwordInputType = InputType.Password;
            passwordIcon = Icons.Material.Filled.VisibilityOff;
        }
    }

    private async Task CreateUserAccount()
    {
        if (selectedStaff == null || !selectedStaffId.HasValue || string.IsNullOrEmpty(email) || string.IsNullOrEmpty(selectedRole))
        {
            Snackbar.Add("Please fill in all required fields.", Severity.Warning);
            return;
        }

        if (!autoGeneratePassword && string.IsNullOrEmpty(password))
        {
            Snackbar.Add("Please enter a password or enable auto-generation.", Severity.Warning);
            return;
        }

        try
        {
            isCreating = true;

            var request = new CreateUserRequest
            {
                StaffId = selectedStaffId.Value,
                Email = email,
                Role = selectedRole,
                Password = password,
                AutoGeneratePassword = autoGeneratePassword
            };

            // Get IP address for audit logging
            var ipAddress = GetClientIpAddress();

            var result = await UserService.CreateUserAsync(request, _tenantId, _userId, ipAddress);

            if (result.Success)
            {
                Snackbar.Add(result.Message, Severity.Success);
                
                // Reset form
                selectedStaff = null;
                selectedStaffId = null;
                email = string.Empty;
                selectedRole = string.Empty;
                password = string.Empty;
                autoGeneratePassword = false;
                form?.ResetValidation();
                StateHasChanged();

                // Redirect to User Management List Page
                Navigation.NavigateTo("/admin/users");
            }
            else
            {
                Snackbar.Add(result.Message, Severity.Error);
            }
        }
        catch (Exception ex)
        {
            var errorMessage = ex.InnerException?.Message ?? ex.Message;
            Snackbar.Add($"Error creating user: {errorMessage}", Severity.Error);
        }
        finally
        {
            isCreating = false;
        }
    }

    private async Task UpdateUserAccount()
    {
        if (!_editUserId.HasValue || string.IsNullOrEmpty(selectedRole))
        {
            Snackbar.Add("Please select a role.", Severity.Warning);
            return;
        }

        try
        {
            isCreating = true;

            var request = new UpdateUserRequest
            {
                UserId = _editUserId.Value,
                Email = email,
                Role = selectedRole,
                IsActive = _existingUser?.IsActive ?? true
            };

            // Get IP address for audit logging
            var ipAddress = GetClientIpAddress();

            var success = await UserService.UpdateAsync(request, _tenantId, _userId, ipAddress);

            if (success)
            {
                Snackbar.Add("User updated successfully", Severity.Success);
                Navigation.NavigateTo("/admin/users");
            }
            else
            {
                Snackbar.Add("Failed to update user", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            var errorMessage = ex.InnerException?.Message ?? ex.Message;
            Snackbar.Add($"Error updating user: {errorMessage}", Severity.Error);
        }
        finally
        {
            isCreating = false;
        }
    }

    private void NavigateBack()
    {
        Navigation.NavigateTo("/admin/users");
    }

    private string? GetClientIpAddress()
    {
        try
        {
            var httpContext = HttpContextAccessor.HttpContext;
            if (httpContext == null) return null;

            // Check for forwarded IP (if behind proxy/load balancer)
            var forwardedFor = httpContext.Request.Headers["X-Forwarded-For"].FirstOrDefault();
            if (!string.IsNullOrEmpty(forwardedFor))
            {
                var ips = forwardedFor.Split(',');
                if (ips.Length > 0)
                {
                    return ips[0].Trim();
                }
            }

            // Check for real IP
            var realIp = httpContext.Request.Headers["X-Real-IP"].FirstOrDefault();
            if (!string.IsNullOrEmpty(realIp))
            {
                return realIp;
            }

            // Fallback to connection remote IP
            return httpContext.Connection.RemoteIpAddress?.ToString();
        }
        catch
        {
            return null;
        }
    }

    public void Dispose()
    {
    }
}

