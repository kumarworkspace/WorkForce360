<MudDrawer @bind-Open="_drawerOpen"
           ClipMode="DrawerClipMode.Always"
           Variant="DrawerVariant.Mini"
           Breakpoint="@_variantBreakpoint"
           Elevation="2"
           Class="@DrawerCssClass"
           @onmouseenter="@OnMouseEnter"
           @onmouseleave="@OnMouseLeave">

    <div class="menu-content-wrapper">
        <MudDrawerHeader class="menu-header">
            <div class="menu-header-content">
                <MudIcon Icon="@Icons.Material.Filled.Business" Size="Size.Large" Color="Color.Primary" />
                @if (_drawerOpen)
                {
                    <MudText Typo="Typo.h6" Class="ml-2">WorkForce360</MudText>
                }
            </div>
            @if (_drawerOpen)
            {
                <MudIconButton Icon="@(_isPinned ? Icons.Material.Filled.PushPin : Icons.Material.Filled.Menu)"
                               Color="@(_isPinned ? Color.Primary : Color.Inherit)"
                               OnClick="@TogglePin" />
            }
        </MudDrawerHeader>

        <MudNavMenu>
            <MudNavLink Href="/dashboard" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Dashboard">Dashboard</MudNavLink>

            @foreach (var group in _visibleGroups)
            {
                <MudNavGroup Title="@group.Title" Icon="@group.GroupIcon" Expanded="false">
                    @foreach (var item in group.Items)
                    {
                        <MudNavLink Href="@item.Href" Icon="@item.Icon">@item.Label</MudNavLink>
                    }
                </MudNavGroup>
            }
        </MudNavMenu>
    </div>
</MudDrawer>

@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using HRMS.Core.Application.Interfaces
@using HRMS.Core.Domain.Interfaces
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IUnitOfWorkFactory UnitOfWorkFactory
@inject NavigationManager Navigation
@inject ILogger<NavMenu> Logger
@implements IDisposable

@code {
    private bool _drawerOpen = false;
    private bool _isPinned = false;
    private Breakpoint _variantBreakpoint = Breakpoint.None;

    private List<NavGroup> _visibleGroups = new();

    private bool _permissionsLoaded = false;
    private int _userId;
    private int _tenantId;
    private string? _previousPath;

    // Paths that can change role/permission/menu assignments — force reload when navigating away
    private static readonly HashSet<string> PermissionChangingPaths = new(StringComparer.OrdinalIgnoreCase)
    {
        "/admin/access-control", "/admin/user-roles", "/admin/users", "/admin/roles", "/admin/menu-management"
    };

    protected override void OnInitialized()
    {
        Navigation.LocationChanged += OnLocationChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _permissionsLoaded) return;
        await LoadMenuAsync();
    }

    private async void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        var prev = _previousPath ?? string.Empty;
        _previousPath = e.Location;

        var prevPath = "/" + prev.Replace(Navigation.BaseUri, "").TrimStart('/').Split('?')[0].TrimStart('/');
        var newPath  = "/" + e.Location.Replace(Navigation.BaseUri, "").TrimStart('/').Split('?')[0].TrimStart('/');

        bool wasOnPermissionPage = PermissionChangingPaths.Any(p => prevPath.StartsWith(p, StringComparison.OrdinalIgnoreCase));
        bool isOnPermissionPage  = PermissionChangingPaths.Any(p => newPath.StartsWith(p, StringComparison.OrdinalIgnoreCase));

        if (wasOnPermissionPage || isOnPermissionPage)
        {
            _permissionsLoaded = false;
            await InvokeAsync(async () =>
            {
                await LoadMenuAsync();
                StateHasChanged();
            });
        }
    }

    private async Task LoadMenuAsync()
    {
        if (_permissionsLoaded) return;
        _permissionsLoaded = true;

        try
        {
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;

            if (user.Identity?.IsAuthenticated != true) return;

            var userIdClaim   = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;
            var tenantIdClaim = user.FindFirst("TenantId")?.Value;

            if (!int.TryParse(userIdClaim,   out _userId)  ||
                !int.TryParse(tenantIdClaim, out _tenantId))
            {
                Logger.LogWarning("NavMenu: could not parse userId='{U}' or tenantId='{T}' from claims", userIdClaim, tenantIdClaim);
                return;
            }

            Dictionary<string, int> permissions;
            IEnumerable<HRMS.Core.Domain.Entities.MenuGroup> dbGroups;

            using (var uow = UnitOfWorkFactory.Create())
            {
                permissions = await LoadPermissionsAsync(uow, _userId, _tenantId);
                dbGroups    = await uow.MenuGroup.GetWithItemsAsync(_tenantId);
            }

            _visibleGroups = dbGroups
                .Where(g => g.IsActive)
                .OrderBy(g => g.SortOrder)
                .Select(g => new NavGroup(
                    g.Title,
                    g.Icon,
                    g.MenuItems
                        .Where(i => i.IsActive &&
                                    (i.PermissionModule == null ||
                                     permissions.GetValueOrDefault(i.PermissionModule, 0) > 0))
                        .OrderBy(i => i.SortOrder)
                        .Select(i => new NavItem(i.Label, i.Href, i.Icon, i.PermissionModule ?? string.Empty))
                        .ToList()
                ))
                .Where(g => g.Items.Count > 0)
                .ToList();

            StateHasChanged();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "NavMenu: error loading menu");
            _visibleGroups = new();
        }
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= OnLocationChanged;
    }

    private string DrawerCssClass => _drawerOpen ? "menu-drawer opened" : "menu-drawer collapsed";

    private void TogglePin()
    {
        _isPinned = !_isPinned;
        if (_isPinned)
        {
            _variantBreakpoint = Breakpoint.Always;
            _drawerOpen = true;
        }
        else
        {
            _variantBreakpoint = Breakpoint.None;
            _drawerOpen = false;
        }
    }

    private void OnMouseEnter() { if (!_isPinned) _drawerOpen = true; }
    private void OnMouseLeave() { if (!_isPinned) _drawerOpen = false; }

    private static async Task<Dictionary<string, int>> LoadPermissionsAsync(IUnitOfWork uow, int userId, int tenantId)
    {
        var userRoles = await uow.UserRole.GetByUserIdAsync(userId, tenantId);
        if (!userRoles.Any()) return new();

        var permissions = await uow.Permission.GetByTenantIdAsync(tenantId);
        var roleIds     = userRoles.Select(ur => ur.RoleId).ToList();
        var result      = new Dictionary<string, int>(StringComparer.OrdinalIgnoreCase);

        foreach (var perm in permissions)
        {
            var rolePerms = await uow.RolePermission.GetByPermissionIdAsync(perm.PermissionId, tenantId);
            var maxLevel  = rolePerms
                .Where(rp => roleIds.Contains(rp.RoleId) && rp.IsActive)
                .Select(rp => rp.AccessLevel)
                .DefaultIfEmpty(0)
                .Max();
            result[perm.ModuleName] = maxLevel;
        }

        return result;
    }

    private record NavItem(string Label, string Href, string Icon, string Permission);
    private record NavGroup(string Title, string GroupIcon, List<NavItem> Items);
}
