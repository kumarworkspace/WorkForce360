@inherits LayoutComponentBase
@inject NavigationManager Navigation
@inject IDialogService DialogService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IServiceScopeFactory ScopeFactory
@inject ILogger<MainLayout> Logger
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@implements IDisposable

<MudProviderComponent />

<MudLayout>
    <MudAppBar Elevation="1" Style="    background-color: #F8F9FE;
    border: none;
    box-shadow: none;">
        <MudSpacer />
        <div class="d-flex align-center mr-4">
            <MudIconButton Icon="@Icons.Material.Filled.HelpOutline" Class="mr-2" />
            <MudIconButton Icon="@Icons.Material.Filled.Notifications" Class="mr-2">
                <MudBadge Content="9" Color="Color.Error" Overlap="true">
                </MudBadge>
            </MudIconButton>
            <MudMenu AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight">
                <ActivatorContent>
                    @if (!string.IsNullOrEmpty(userProfilePicture))
                    {
                        <MudAvatar Size="Size.Small" Style="cursor: pointer;">
                            <MudImage Src="@userProfilePicture" />
                        </MudAvatar>
                    }
                    else
                    {
                        <MudAvatar Size="Size.Small" Style="cursor: pointer;">@userInitial</MudAvatar>
                    }
                </ActivatorContent>
                <ChildContent>
                    <MudMenuItem Icon="@Icons.Material.Filled.Person" Href="/profile">My Profile</MudMenuItem>
                    <MudDivider />
                    <MudMenuItem Icon="@Icons.Material.Filled.Logout" OnClick="OpenLogoutDialog">Log Out</MudMenuItem>
                </ChildContent>
            </MudMenu>
        </div>
    </MudAppBar>
    <MudDrawerContainer Style="height: 100vh; display:flex; flex-direction:row; background-color:#F8F9FE">
        <!-- Full-height sidebar -->
        <NavMenu />

        <!-- Main body content -->
        <MudMainContent Style="flex:1; overflow-y:auto;">
            <MudContainer MaxWidth="MaxWidth.False" Class="pa-4">
                @if (!_accessCheckDone)
                {
                    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
                }
                else if (_hasPageAccess)
                {
                    @Body
                }
                else
                {
                    <MudPaper Elevation="2" Class="pa-8" Style="text-align:center; max-width:500px; margin:64px auto; border-radius:12px;">
                        <MudIcon Icon="@Icons.Material.Filled.Lock" Size="Size.Large" Color="Color.Error" Style="font-size:64px;" />
                        <MudText Typo="Typo.h5" Class="mt-3 mb-2" Style="font-weight:600;">Access Denied</MudText>
                        <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mb-4">
                            You do not have permission to access this page.
                        </MudText>
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@(() => Navigation.NavigateTo("/dashboard"))">
                            Go to Dashboard
                        </MudButton>
                    </MudPaper>
                }
            </MudContainer>
        </MudMainContent>
    </MudDrawerContainer>
</MudLayout>

@code {
    private const string DefaultInitial = "U";
    private const string DefaultUserName = "User";
    private const string OpenIdConnectAuthType = "OpenIdConnect";
    private const string FederationAuthType = "AuthenticationTypes.Federation";
    private const string LogoutPath = "/logout";

    private string userInitial = DefaultInitial;
    private string userProfilePicture = string.Empty;
    private string userName = string.Empty;

    private bool _hasPageAccess = true;
    private bool _accessCheckDone = true;
    private int _userId;
    private int _tenantId;
    private string? _userRole;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity?.IsAuthenticated != true)
            return;

        Logger.LogInformation("User authenticated - AuthType: {AuthType}", user.Identity.AuthenticationType);

        userName = IsSsoAuthentication(user.Identity.AuthenticationType)
            ? GetSsoUserName(user)
            : GetCookieUserName(user);

        SetUserInitial();

        int.TryParse(user.FindFirst(ClaimTypes.NameIdentifier)?.Value, out _userId);
        int.TryParse(user.FindFirst("TenantId")?.Value, out _tenantId);
        _userRole = user.FindFirst(ClaimTypes.Role)?.Value;

        Navigation.LocationChanged += OnLocationChanged;
        await CheckCurrentPageAccessAsync();
    }

    private async void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        _accessCheckDone = false;
        await InvokeAsync(async () =>
        {
            await CheckCurrentPageAccessAsync();
            StateHasChanged();
        });
    }

    private static readonly HashSet<string> AlwaysAllowedPaths = new(StringComparer.OrdinalIgnoreCase)
    {
        "/dashboard", "/profile", "/signin", "/logout"
    };

    private async Task CheckCurrentPageAccessAsync()
    {
        if (_userId == 0 || _tenantId == 0)
        {
            _hasPageAccess = true;
            _accessCheckDone = true;
            return;
        }

        var path = "/" + Navigation.Uri.Replace(Navigation.BaseUri, "").TrimStart('/').Split('?')[0].TrimStart('/');

        // Super Admin bypasses all access checks
        if (string.Equals(_userRole, HRMS.Core.Application.AppConstants.Roles.SuperAdmin, StringComparison.OrdinalIgnoreCase)
            || AlwaysAllowedPaths.Contains(path)
            || path == "/")
        {
            _hasPageAccess = true;
            _accessCheckDone = true;
            return;
        }

        // Always do a fresh DB check — no cache to ensure permissions reflect latest changes
        using var scope = ScopeFactory.CreateScope();
        var authHelper = scope.ServiceProvider.GetRequiredService<IAuthorizationHelper>();
        _hasPageAccess = await authHelper.HasPageAccessAsync(_userId, path, _tenantId);
        _accessCheckDone = true;
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= OnLocationChanged;
    }

    private bool IsSsoAuthentication(string? authType) =>
        authType == OpenIdConnectAuthType || authType == FederationAuthType;

    private string GetSsoUserName(ClaimsPrincipal user)
    {
        var name = user.FindFirst(ClaimTypes.Name)?.Value
            ?? user.FindFirst("name")?.Value
            ?? user.FindFirst(ClaimTypes.Email)?.Value
            ?? user.FindFirst("preferred_username")?.Value
            ?? DefaultUserName;

        userProfilePicture = user.FindFirst("picture")?.Value ?? string.Empty;
        Logger.LogInformation("SSO user - userName: {UserName}", name);

        return name;
    }

    private string GetCookieUserName(ClaimsPrincipal user)
    {
        var name = user.FindFirst("Username")?.Value
            ?? user.FindFirst(ClaimTypes.Name)?.Value
            ?? user.FindFirst(ClaimTypes.Email)?.Value
            ?? user.Identity?.Name
            ?? DefaultUserName;

        Logger.LogInformation("Cookie auth user - userName: {UserName}", name);

        return name;
    }

    private void SetUserInitial()
    {
        if (string.IsNullOrWhiteSpace(userName))
        {
            Logger.LogWarning("userName is null or empty, keeping default initial '{DefaultInitial}'", DefaultInitial);
            return;
        }

        userInitial = userName.Trim()[0].ToString().ToUpper();
        Logger.LogInformation("User initial set: {UserInitial}", userInitial);
    }

    private async Task OpenLogoutDialog()
    {
        var options = new DialogOptions
        {
            CloseButton = true,
            CloseOnEscapeKey = true,
            MaxWidth = MaxWidth.Small,
            FullWidth = true
        };

        var dialog = await DialogService.ShowAsync<LogoutConfirmationDialog>(
            "Logout Confirmation?",
            new DialogParameters(),
            options);

        var result = await dialog.Result;

        if (!result.Canceled)
        {
            Navigation.NavigateTo(LogoutPath, forceLoad: true);
        }
    }
}

